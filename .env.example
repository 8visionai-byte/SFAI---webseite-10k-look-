# Ustaw te wartości wyłącznie w zmiennych środowiskowych hostingu.
# Nigdy nie umieszczaj prawdziwego klucza w repozytorium ani w kodzie przeglądarki.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-sol
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_VOICE=cedar

# Opcjonalnie: baza wiedzy OpenAI File Search. Bez niej agent korzysta z
# zatwierdzonej wiedzy o firmie zapisanej w api/_knowledge.mjs.
OPENAI_VECTOR_STORE_ID=

# Opcjonalnie: edytowalna baza wiedzy bez zmian w kodzie. URL do ZWYKŁEGO TEKSTU,
# np. Google Doc opublikowany "do internetu" w formacie txt:
# https://docs.google.com/document/d/e/<ID_PUBLIKACJI>/pub?output=txt
# Treść jest doklejana do wiedzy wbudowanej jako źródło nadrzędne (czat i głos),
# cache ~5 minut, limit 24 000 znaków. Błąd pobierania = cichy powrót do wiedzy wbudowanej.
KNOWLEDGE_DOC_URL=
