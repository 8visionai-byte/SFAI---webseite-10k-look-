---
import { Image } from 'astro:assets';
import poster from '../assets/generated/v2/system-hero.png';
---
<div class="flow-core" data-flow-core aria-hidden="true">
  <div class="flow-core-poster">
    <Image src={poster} alt="" widths={[640, 960, 1280]} sizes="(max-width: 720px) 118vw, 64vw" format="webp" quality={82} loading="eager" />
  </div>
  <canvas data-flow-canvas></canvas>
  <div class="flow-metal-hud">
    <span>[ Adaptive matter ]</span>
    <span data-metal-state>Signal / 01</span>
  </div>
  <div class="flow-metal-index"><i></i><span>Liquid logic</span><b>SF / AI</b></div>
</div>

<script>
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

  const bootFlowCore = async () => {
    const [THREE, environmentModule] = await Promise.all([
      import('three'),
      import('three/examples/jsm/environments/RoomEnvironment.js'),
    ]);
    const { RoomEnvironment } = environmentModule;

    document.querySelectorAll('[data-flow-core]').forEach((container) => {
    const canvas = container.querySelector('[data-flow-canvas]');
    const stateLabel = container.querySelector('[data-metal-state]');
    if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.ready) return;
    canvas.dataset.ready = 'true';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mobile = window.matchMedia('(max-width: 760px)').matches;
    if (reduced) {
      container.classList.add('is-static');
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(mobile ? 32 : 27, 1, 0.1, 50);
    camera.position.set(mobile ? 0.35 : 0.15, 0, mobile ? 10.4 : 11.55);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: !mobile,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, mobile ? 1.15 : 1.65));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;

    const pmrem = new THREE.PMREMGenerator(renderer);
    const room = new RoomEnvironment();
    const environment = pmrem.fromScene(room, 0.035).texture;
    scene.environment = environment;
    room.dispose();
    pmrem.dispose();

    const sculpture = new THREE.Group();
    sculpture.position.set(mobile ? 0.82 : 0.68, mobile ? -0.18 : 0.04, 0);
    scene.add(sculpture);

    const geometry = new THREE.TorusGeometry(
      mobile ? 1.33 : 1.42,
      mobile ? 0.79 : 0.86,
      mobile ? 72 : 112,
      mobile ? 128 : 220,
    );
    geometry.scale(mobile ? 1.12 : 1.18, mobile ? 1.32 : 1.38, mobile ? 0.82 : 0.88);

    const material = new THREE.MeshPhysicalMaterial({
      color: 0x777e84,
      metalness: 1,
      roughness: 0.072,
      clearcoat: 1,
      clearcoatRoughness: 0.07,
      iridescence: 0.62,
      iridescenceIOR: 1.38,
      iridescenceThicknessRange: [180, 520],
      envMapIntensity: 2.15,
    });

    const shaderState = { shader: null };
    material.onBeforeCompile = (shader) => {
      shader.uniforms.uTime = { value: 0 };
      shader.uniforms.uProgress = { value: 0 };
      shader.uniforms.uPointer = { value: new THREE.Vector2() };
      shaderState.shader = shader;

      shader.vertexShader = shader.vertexShader
        .replace(
          '#include <common>',
          `#include <common>
          uniform float uTime;
          uniform float uProgress;
          uniform vec2 uPointer;

          float fluidField(vec3 p, float t) {
            float broad = sin(p.x * 1.18 + t * .52) * cos(p.y * .82 - t * .31);
            float fold = sin((p.y + p.z) * 1.46 - t * .43) * .58;
            float current = cos((p.x - p.z) * 1.72 + t * .27) * .36;
            return broad + fold + current;
          }`
        )
        .replace(
          '#include <beginnormal_vertex>',
          `#include <beginnormal_vertex>
          float normalAngle = atan(position.y, position.x);
          objectNormal = normalize(objectNormal + vec3(
            cos(position.y * .82 - uTime * .2) * .15,
            -sin(position.x * .74 + uTime * .16) * .13,
            cos(normalAngle * 2.0 + uTime * .34 + uProgress * 1.8) * .24
          ));`
        )
        .replace(
          '#include <begin_vertex>',
          `vec3 transformed = vec3(position);
          float t = uTime;
          float field = fluidField(position, t);
          float angle = atan(position.y, position.x);
          float broadFold = sin(angle * 2.0 + t * .34 + uProgress * 1.8);
          float secondaryFold = cos(angle * 3.0 - t * .23);
          float displacement = field * (.105 + uProgress * .035) + broadFold * .1;
          transformed += normalize(objectNormal) * displacement;
          transformed.x *= 1.0 + broadFold * .13;
          transformed.y *= 1.0 + secondaryFold * .1;
          transformed.z += broadFold * (.31 + uProgress * .08);
          transformed.z += sin((position.x - position.y) * .72 - t * .19) * .14;
          transformed.x += sin(position.y * .82 - t * .2) * (.18 + uProgress * .08);
          transformed.y += cos(position.x * .74 + t * .16) * .13;
          transformed.x += uPointer.x * (position.y * .035);
          transformed.y += uPointer.y * (position.x * .028);`
        );
    };

    const mesh = new THREE.Mesh(geometry, material);
    mesh.rotation.set(-0.18, -0.42, -0.08);
    sculpture.add(mesh);

    scene.add(new THREE.HemisphereLight(0xe7ebff, 0x050606, 1.18));
    const whiteKey = new THREE.DirectionalLight(0xffffff, 4.6);
    whiteKey.position.set(-3.4, 4.8, 6.5);
    scene.add(whiteKey);
    const cobaltRim = new THREE.DirectionalLight(0x5368ff, 5.4);
    cobaltRim.position.set(4.8, 1.4, 4.2);
    scene.add(cobaltRim);
    const warmRim = new THREE.DirectionalLight(0xffa55f, 3.2);
    warmRim.position.set(-4.6, -2.8, 3.4);
    scene.add(warmRim);
    const cyanFill = new THREE.PointLight(0x6de8ff, 10, 14);
    cyanFill.position.set(0.5, -4.5, 4.8);
    scene.add(cyanFill);

    let targetProgress = mobile ? 0.47 : 0;
    let progress = targetProgress;
    let targetPointerX = 0;
    let targetPointerY = 0;
    let pointerX = 0;
    let pointerY = 0;
    let visible = true;
    let running = false;
    let frameId = 0;
    let lastFrame = 0;
    const startedAt = performance.now();
    const hero = container.closest('[data-hero]');
    const stateNames = ['Signal / 01', 'Context / 02', 'Motion / 03', 'Result / 04'];

    const setProgress = (value) => {
      targetProgress = mobile ? 0.47 : clamp(value, 0, 1);
      container.style.setProperty('--metal-progress', String(targetProgress));
      if (stateLabel) stateLabel.textContent = stateNames[Math.min(3, Math.floor(targetProgress * 4))];
    };

    const onHeroProgress = (event) => {
      if (event instanceof CustomEvent && typeof event.detail?.progress === 'number') setProgress(event.detail.progress);
    };
    hero?.addEventListener('sfai:hero-progress', onHeroProgress);

    if (!mobile && hero) {
      const rect = hero.getBoundingClientRect();
      const range = Math.max(1, hero.scrollHeight - innerHeight);
      setProgress(-rect.top / range);
    }

    const onPointerMove = (event) => {
      if (mobile || event.pointerType === 'touch') return;
      const rect = container.getBoundingClientRect();
      const inside = event.clientX >= rect.left && event.clientX <= rect.right && event.clientY >= rect.top && event.clientY <= rect.bottom;
      if (!inside) {
        targetPointerX = 0;
        targetPointerY = 0;
        return;
      }
      targetPointerX = clamp((event.clientX - rect.left) / rect.width - 0.5, -0.5, 0.5);
      targetPointerY = clamp((event.clientY - rect.top) / rect.height - 0.5, -0.5, 0.5);
    };
    window.addEventListener('pointermove', onPointerMove, { passive: true });

    const resize = () => {
      const rect = container.getBoundingClientRect();
      const width = Math.max(1, rect.width);
      const height = Math.max(1, rect.height);
      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    };
    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(container);
    resize();

    const updateScene = (time) => {
      progress += (targetProgress - progress) * 0.055;
      pointerX += (targetPointerX - pointerX) * 0.045;
      pointerY += (targetPointerY - pointerY) * 0.045;

      const seconds = (time - startedAt) * 0.001;
      const shader = shaderState.shader;
      if (shader) {
        shader.uniforms.uTime.value = seconds;
        shader.uniforms.uProgress.value = progress;
        shader.uniforms.uPointer.value.set(pointerX, pointerY);
      }

      const idle = Math.sin(seconds * 0.34) * 0.025;
      mesh.rotation.x = -0.2 + progress * 0.22 + pointerY * 0.18 + idle;
      mesh.rotation.y = -0.48 + progress * 0.66 + pointerX * 0.22;
      mesh.rotation.z = -0.09 + progress * 0.18 - pointerX * 0.08;
      sculpture.position.y = (mobile ? -0.18 : 0.04) + Math.sin(seconds * 0.42) * 0.045 - progress * 0.08;
      sculpture.scale.setScalar(0.95 + progress * 0.08);
      material.roughness = 0.068 + progress * 0.042;
      material.iridescence = 0.52 + Math.sin(seconds * 0.28) * 0.08 + progress * 0.1;
      cobaltRim.intensity = 4.7 + progress * 2.1;
      warmRim.intensity = 2.7 + (1 - progress) * 1.2;
    };

    const render = (time) => {
      if (!running) return;
      frameId = requestAnimationFrame(render);
      if (mobile && time - lastFrame < 32) return;
      lastFrame = time;
      if (document.hidden || document.body.classList.contains('menu-open')) return;
      updateScene(time);
      renderer.render(scene, camera);
    };

    const start = () => {
      if (running || !visible) return;
      running = true;
      frameId = requestAnimationFrame(render);
    };
    const stop = () => {
      running = false;
      cancelAnimationFrame(frameId);
    };

    const intersectionObserver = new IntersectionObserver(([entry]) => {
      visible = entry.isIntersecting;
      visible ? start() : stop();
    }, { rootMargin: '120px' });
    intersectionObserver.observe(container);

    const onVisibility = () => document.hidden ? stop() : start();
    document.addEventListener('visibilitychange', onVisibility);
    canvas.addEventListener('webglcontextlost', () => container.classList.remove('is-rendered'), { passive: true });

    const cleanup = () => {
      stop();
      resizeObserver.disconnect();
      intersectionObserver.disconnect();
      window.removeEventListener('pointermove', onPointerMove);
      document.removeEventListener('visibilitychange', onVisibility);
      hero?.removeEventListener('sfai:hero-progress', onHeroProgress);
      scene.traverse((object) => {
        if (object instanceof THREE.Mesh) {
          object.geometry?.dispose();
          const materials = Array.isArray(object.material) ? object.material : [object.material];
          materials.forEach((entry) => entry?.dispose());
        }
      });
      environment.dispose();
      renderer.dispose();
    };
    window.addEventListener('pagehide', cleanup, { once: true });

    start();
    requestAnimationFrame(() => container.classList.add('is-rendered'));
    });
  };

  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => void bootFlowCore(), { timeout: 900 });
  } else {
    window.setTimeout(() => void bootFlowCore(), 120);
  }
</script>
