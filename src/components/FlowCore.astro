<div class="flow-core" data-flow-core>
  <canvas data-flow-canvas aria-hidden="true"></canvas>

  <div class="flow-metal-hud" aria-hidden="true">
    <span>[ Magnetic intelligence ]</span>
    <span data-metal-state>Signal / 01</span>
  </div>

  <button
    class="voice-core-trigger"
    type="button"
    data-voice-trigger
    aria-label="Otwórz prototyp voice agenta"
    aria-expanded="false"
    aria-controls="voice-core-panel"
  >
    <span class="voice-core-orbit" aria-hidden="true"><i></i><b></b></span>
    <span class="voice-core-label">Zapytaj AI</span>
    <span class="voice-core-caption" aria-hidden="true">Voice agent</span>
  </button>

  <div class="voice-core-panel" id="voice-core-panel" data-voice-panel role="region" aria-label="Prototyp voice agenta" hidden>
    <span class="eyebrow">[ Interfejs głosowy ]</span>
    <p data-voice-status role="status" aria-live="polite">Tu uruchomisz rozmowę z agentem znającym ofertę SimpleFast.ai.</p>
    <small>Prototyp interfejsu — gotowy do połączenia z bazą wiedzy i modułem głosowym.</small>
  </div>

  <div class="flow-metal-index" aria-hidden="true"><i></i><span>Living interface</span><b>SF / AI</b></div>
</div>

<script>
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

  const bootFlowCore = async () => {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    for (const container of document.querySelectorAll('[data-flow-core]')) {
      const canvas = container.querySelector('[data-flow-canvas]');
      const stateLabel = container.querySelector('[data-metal-state]');
      if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.ready) continue;

      canvas.dataset.ready = 'true';
      if (reduced) {
        container.classList.add('is-static', 'is-rendered');
        continue;
      }

      const mobile = window.matchMedia('(max-width: 760px)').matches;

      try {
        const THREE = await import('three');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(mobile ? 34 : 30, 1, 0.1, 40);
        camera.position.set(mobile ? 0.28 : 0.08, 0, mobile ? 10.1 : 9.75);

        const renderer = new THREE.WebGLRenderer({
          canvas,
          alpha: true,
          antialias: !mobile,
          powerPreference: 'high-performance',
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, mobile ? 1.1 : 1.5));
        renderer.outputColorSpace = THREE.SRGBColorSpace;
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        renderer.toneMappingExposure = 1.04;

        const sculpture = new THREE.Group();
        sculpture.position.set(mobile ? 0.76 : 0.54, mobile ? -0.05 : 0.02, 0);
        scene.add(sculpture);

        const geometry = new THREE.IcosahedronGeometry(mobile ? 1.5 : 1.66, mobile ? 4 : 5);
        geometry.scale(mobile ? 1.08 : 1.16, mobile ? 0.98 : 1.04, mobile ? 0.76 : 0.82);

        const material = new THREE.MeshPhysicalMaterial({
          color: 0xb8bcbe,
          metalness: 0.94,
          roughness: 0.155,
          clearcoat: 0.48,
          clearcoatRoughness: 0.12,
          iridescence: 0.065,
          iridescenceIOR: 1.25,
          iridescenceThicknessRange: [110, 220],
          envMapIntensity: 0.15,
        });

        const shaderState = { shader: null };
        material.onBeforeCompile = (shader) => {
          shader.uniforms.uTime = { value: 0 };
          shader.uniforms.uProgress = { value: 0 };
          shader.uniforms.uPointer = { value: new THREE.Vector2() };
          shaderState.shader = shader;

          shader.vertexShader = shader.vertexShader
            .replace(
              '#include <common>',
              `#include <common>
              uniform float uTime;
              uniform float uProgress;
              uniform vec2 uPointer;

              float magneticField(vec3 p, float t) {
                float broad = sin(p.x * 1.13 + t * .33) * cos(p.y * .91 - t * .25);
                float fold = sin((p.y + p.z) * 1.42 - t * .28) * .54;
                float current = cos((p.x - p.z) * 1.58 + t * .21) * .32;
                return broad + fold + current;
              }`
            )
            .replace(
              '#include <beginnormal_vertex>',
              `#include <beginnormal_vertex>
              objectNormal = normalize(objectNormal + vec3(
                cos(position.y * 1.1 - uTime * .18) * .045,
                -sin(position.x * .96 + uTime * .15) * .04,
                cos((position.x + position.y) * .88 + uTime * .2) * .055
              ));`
            )
            .replace(
              '#include <begin_vertex>',
              `vec3 transformed = vec3(position);
              float field = magneticField(position, uTime);
              float displacement = field * (.155 + uProgress * .022);
              transformed += normalize(objectNormal) * displacement;
              transformed.x *= 1.0 + sin(position.y * .62 - uTime * .12) * .07;
              transformed.y *= 1.0 + cos(position.x * .57 + uTime * .11) * .055;
              transformed.x += sin(position.y * 1.06 - uTime * .2) * (.078 + uProgress * .018);
              transformed.y += cos(position.x * .9 + uTime * .16) * .064;
              transformed.z += sin((position.x - position.y) * .75 - uTime * .15) * .105;
              transformed.x += uPointer.x * position.y * .022;
              transformed.y += uPointer.y * position.x * .018;`
            );
        };

        const mesh = new THREE.Mesh(geometry, material);
        mesh.rotation.set(-0.13, -0.48, -0.12);
        sculpture.add(mesh);

        scene.add(new THREE.HemisphereLight(0xf3f5f2, 0x080909, 0.92));
        const whiteKey = new THREE.DirectionalLight(0xffffff, 3.6);
        whiteKey.position.set(-3.2, 4.8, 6.4);
        scene.add(whiteKey);
        const limeEdge = new THREE.DirectionalLight(0xc8ff45, 1.35);
        limeEdge.position.set(-4.2, -1.8, 3.2);
        scene.add(limeEdge);
        const cobaltEdge = new THREE.DirectionalLight(0x3159ff, 1.12);
        cobaltEdge.position.set(4.6, 1.6, 3.8);
        scene.add(cobaltEdge);
        const coolFill = new THREE.PointLight(0xd6f5f0, 2.2, 14);
        coolFill.position.set(0.8, -4, 4.5);
        scene.add(coolFill);
        const warmPin = new THREE.PointLight(0xffc39a, 1.35, 12);
        warmPin.position.set(-3.8, 2.8, 2.4);
        scene.add(warmPin);

        let environment = null;
        let targetEnvIntensity = 0.15;
        let disposed = false;
        let targetProgress = mobile ? 0.42 : 0;
        let progress = targetProgress;
        let targetPointerX = 0;
        let targetPointerY = 0;
        let pointerX = 0;
        let pointerY = 0;
        let visible = true;
        let running = false;
        let frameId = 0;
        let lastFrame = 0;
        const startedAt = performance.now();
        const hero = container.closest('[data-hero]');
        const stateNames = ['Signal / 01', 'Context / 02', 'Motion / 03', 'Result / 04'];

        const setProgress = (value) => {
          targetProgress = mobile ? 0.42 : clamp(value, 0, 1);
          container.style.setProperty('--metal-progress', String(targetProgress));
          if (stateLabel) stateLabel.textContent = stateNames[Math.min(3, Math.floor(targetProgress * 4))];
        };

        const onHeroProgress = (event) => {
          if (event instanceof CustomEvent && typeof event.detail?.progress === 'number') setProgress(event.detail.progress);
        };
        hero?.addEventListener('sfai:hero-progress', onHeroProgress);

        if (!mobile && hero) {
          const rect = hero.getBoundingClientRect();
          setProgress(-rect.top / Math.max(1, hero.scrollHeight - innerHeight));
        }

        const onPointerMove = (event) => {
          if (mobile || event.pointerType === 'touch') return;
          const rect = container.getBoundingClientRect();
          const inside = event.clientX >= rect.left && event.clientX <= rect.right && event.clientY >= rect.top && event.clientY <= rect.bottom;
          targetPointerX = inside ? clamp((event.clientX - rect.left) / rect.width - 0.5, -0.5, 0.5) : 0;
          targetPointerY = inside ? clamp((event.clientY - rect.top) / rect.height - 0.5, -0.5, 0.5) : 0;
        };
        window.addEventListener('pointermove', onPointerMove, { passive: true });

        const resize = () => {
          const rect = container.getBoundingClientRect();
          const width = Math.max(1, rect.width);
          const height = Math.max(1, rect.height);
          renderer.setSize(width, height, false);
          camera.aspect = width / height;
          camera.updateProjectionMatrix();
        };
        const resizeObserver = new ResizeObserver(resize);
        resizeObserver.observe(container);
        resize();

        const updateScene = (time) => {
          progress += (targetProgress - progress) * 0.052;
          pointerX += (targetPointerX - pointerX) * 0.045;
          pointerY += (targetPointerY - pointerY) * 0.045;

          const seconds = (time - startedAt) * 0.001;
          const shader = shaderState.shader;
          if (shader) {
            shader.uniforms.uTime.value = seconds;
            shader.uniforms.uProgress.value = progress;
            shader.uniforms.uPointer.value.set(pointerX, pointerY);
          }

          const idle = Math.sin(seconds * 0.31) * 0.018;
          mesh.rotation.x = -0.13 + progress * 0.13 + pointerY * 0.1 + idle;
          mesh.rotation.y = -0.48 + progress * 0.42 + pointerX * 0.13;
          mesh.rotation.z = -0.12 + progress * 0.11 - pointerX * 0.05;
          sculpture.position.y = (mobile ? -0.05 : 0.02) + Math.sin(seconds * 0.38) * 0.032 - progress * 0.035;
          sculpture.scale.setScalar(0.97 + progress * 0.035);
          material.roughness = 0.15 + progress * 0.022;
          material.envMapIntensity += (targetEnvIntensity - material.envMapIntensity) * 0.075;
          limeEdge.intensity = 1.15 + progress * 0.5;
          cobaltEdge.intensity = 0.92 + progress * 0.4;
        };

        const render = (time) => {
          if (!running) return;
          frameId = requestAnimationFrame(render);
          if (mobile && time - lastFrame < 34) return;
          lastFrame = time;
          if (document.hidden || document.body.classList.contains('menu-open')) return;
          updateScene(time);
          renderer.render(scene, camera);
        };

        const start = () => {
          if (running || !visible) return;
          running = true;
          frameId = requestAnimationFrame(render);
        };
        const stop = () => {
          running = false;
          cancelAnimationFrame(frameId);
        };

        const intersectionObserver = new IntersectionObserver(([entry]) => {
          visible = entry.isIntersecting;
          visible ? start() : stop();
        }, { rootMargin: '120px' });
        intersectionObserver.observe(container);

        const onVisibility = () => document.hidden ? stop() : start();
        document.addEventListener('visibilitychange', onVisibility);
        const onContextLost = (event) => {
          event.preventDefault();
          stop();
          container.classList.add('is-fallback');
        };
        const onContextRestored = () => {
          container.classList.remove('is-fallback');
          start();
        };
        canvas.addEventListener('webglcontextlost', onContextLost);
        canvas.addEventListener('webglcontextrestored', onContextRestored);

        updateScene(performance.now());
        renderer.render(scene, camera);
        container.classList.add('is-rendered');
        start();

        import('three/examples/jsm/environments/RoomEnvironment.js').then(({ RoomEnvironment }) => {
          if (disposed) return;
          const pmrem = new THREE.PMREMGenerator(renderer);
          const room = new RoomEnvironment();
          environment = pmrem.fromScene(room, 0.035).texture;
          scene.environment = environment;
          targetEnvIntensity = 1.2;
          room.dispose();
          pmrem.dispose();
        }).catch(() => undefined);

        const cleanup = () => {
          disposed = true;
          stop();
          resizeObserver.disconnect();
          intersectionObserver.disconnect();
          window.removeEventListener('pointermove', onPointerMove);
          document.removeEventListener('visibilitychange', onVisibility);
          canvas.removeEventListener('webglcontextlost', onContextLost);
          canvas.removeEventListener('webglcontextrestored', onContextRestored);
          hero?.removeEventListener('sfai:hero-progress', onHeroProgress);
          window.removeEventListener('pagehide', onPageHide);
          window.removeEventListener('pageshow', onPageShow);
          scene.traverse((object) => {
            if (object instanceof THREE.Mesh) {
              object.geometry?.dispose();
              const materials = Array.isArray(object.material) ? object.material : [object.material];
              materials.forEach((entry) => entry?.dispose());
            }
          });
          environment?.dispose();
          renderer.dispose();
        };
        const onPageHide = (event) => event.persisted ? stop() : cleanup();
        const onPageShow = (event) => {
          if (event.persisted) start();
        };
        window.addEventListener('pagehide', onPageHide);
        window.addEventListener('pageshow', onPageShow);
      } catch (error) {
        console.warn('Flow Core fallback:', error);
        container.classList.add('is-static', 'is-fallback', 'is-rendered');
      }
    }
  };

  void bootFlowCore();
</script>
