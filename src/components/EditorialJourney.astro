---
import { Image } from 'astro:assets';
import valueArchitectureImage from '../assets/generated/v4/service-value-diagnostic-atlas.png';
import aiCareObservatoryImage from '../assets/generated/v4/service-care-command-observatory.png';
import voicebotImage from '../assets/generated/v4/service-voice-agent-resonance.png';
import chatbotKnowledgeImage from '../assets/generated/v4/service-chatbot-knowledge-dialogue.png';
import seoAiCitationsImage from '../assets/generated/v4/service-geo-citation-ecosystem.png';
import aiAgentControlImage from '../assets/generated/v4/service-agent-human-control.png';
import processAutomationImage from '../assets/generated/v4/service-workflow-business-artifacts.png';
import storyValueDiagnosisImage from '../assets/generated/v4/story-02-value-diagnosis.png';
import storySystemArchitectureImage from '../assets/generated/v4/story-04-system-architecture.png';
import storyControlledActionImage from '../assets/generated/v4/story-06-controlled-action.png';
import storyScaleCareImage from '../assets/generated/v4/story-08-scale-and-care.png';

const fogLayers = [
  {
    src: storyValueDiagnosisImage,
    alt: 'Architektura wartości AI przedstawiona jako uporządkowany system decyzji i priorytetów',
    layer: 'background',
  },
  {
    src: storyControlledActionImage,
    alt: 'Agent AI porządkujący sygnały, decyzje i kontrolowane działania',
    layer: 'subject',
  },
  {
    src: storySystemArchitectureImage,
    alt: 'Architektura systemu AI złożona z połączonych warstw danych i decyzji',
    layer: 'accent',
  },
  {
    src: storyScaleCareImage,
    alt: 'Centrum stałego nadzoru nad agentami i automatyzacjami AI',
    layer: 'foreground',
  },
];

const exploreRows = [
  [
    {
      src: voicebotImage,
      alt: 'Profesjonalny system voicebota obsługującego naturalną rozmowę po polsku',
      label: 'Voiceboty AI',
      detail: 'Rozmowa / intencja / termin',
      direction: 'from-left',
    },
    {
      src: chatbotKnowledgeImage,
      alt: 'Chatbot AI korzystający z kontrolowanej bazy wiedzy firmy',
      label: 'Chatboty AI',
      detail: 'Wiedza / obsługa / lead',
      direction: 'from-right',
    },
  ],
  [
    {
      src: seoAiCitationsImage,
      alt: 'Sieć wiarygodnych źródeł prowadząca do cytowania marki w odpowiedziach AI',
      label: 'SEO + widoczność w AI',
      detail: 'Źródła / znaczenie / cytowanie',
      direction: 'from-bottom-left',
    },
  ],
  [
    {
      src: aiAgentControlImage,
      alt: 'Agent AI wykonujący zadania w granicach wyznaczonych przez człowieka',
      label: 'Agenci AI',
      detail: 'Decyzja / akcja / kontrola',
      direction: 'from-top-right',
    },
    {
      src: processAutomationImage,
      alt: 'Automatyzacja łącząca dane i firmowe narzędzia w jeden precyzyjny proces',
      label: 'Automatyzacja procesów',
      detail: 'Systemy / dane / przepływ',
      direction: 'from-left',
    },
  ],
  [
    {
      src: aiCareObservatoryImage,
      alt: 'Obserwatorium monitorujące jakość i ciągłość działania systemów AI',
      label: 'Opieka AI',
      detail: 'Monitoring / rozwój / spokój',
      direction: 'from-bottom-right',
    },
  ],
];
---

<section class="fog-statement" data-fog-statement aria-labelledby="fog-statement-title">
  <div class="fog-statement__stage" data-fog-stage>
    <div class="fog-statement__media" data-fog-media>
      {fogLayers.map((image, index) => (
        <figure
          class:list={['fog-statement__image', `fog-statement__image--${image.layer}`]}
          data-fog-image={index + 1}
          data-fog-layer={image.layer}
        >
          <Image
            src={image.src}
            alt={image.alt}
            widths={[640, 960, 1440, 1920]}
            sizes="(max-width: 760px) 72vw, 38vw"
            format="webp"
            quality={86}
            loading={index === 0 ? 'eager' : 'lazy'}
            fetchpriority={index === 0 ? 'high' : 'auto'}
          />
        </figure>
      ))}
      <div class="fog-statement__veil" data-fog-veil aria-hidden="true"></div>
    </div>

    <div class="fog-statement__copy" data-fog-copy>
      <p class="mono-label" data-fog-kicker>/ Inteligencja w służbie pracy</p>
      <h2 id="fog-statement-title" data-fog-heading>
        <span data-fog-line>Najlepsze systemy AI</span>
        <span data-fog-line>nie proszą o uwagę.</span>
        <span data-fog-line>Oddają ją ludziom.</span>
      </h2>
      <p data-fog-note>
        Technologia działa w tle. Zespół odzyskuje czas, klient dostaje odpowiedź,
        a każda decyzja pozostaje pod kontrolą.
      </p>
    </div>
  </div>
</section>

<section class="system-explore" data-system-explore aria-labelledby="system-explore-title">
  <div class="system-explore__sticky">
    <div class="system-explore__media-plane" data-explore-media aria-label="Obszary systemu SimpleFast.ai">
      {exploreRows.map((row, rowIndex) => (
        <div class="system-explore__row" data-explore-row={rowIndex + 1}>
          {row.map((item, itemIndex) => (
            <figure
              class="system-explore__item"
              data-explore-item
              data-explore-row-index={rowIndex + 1}
              data-explore-item-index={itemIndex + 1}
              data-explore-direction={item.direction}
            >
              <div class="system-explore__image">
                <Image
                  src={item.src}
                  alt={item.alt}
                  widths={[520, 760, 1080, 1440]}
                  sizes="(max-width: 760px) 68vw, 29vw"
                  format="webp"
                  quality={84}
                  loading={rowIndex === 0 && itemIndex === 0 ? 'eager' : 'lazy'}
                  fetchpriority={rowIndex === 0 && itemIndex === 0 ? 'high' : 'auto'}
                />
              </div>
              <figcaption>
                <strong data-scramble>{item.label}</strong>
                <span>{item.detail}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      ))}
    </div>

    <div class="system-explore__copy">
      <p class="mono-label">/ Jeden partner. Cały system.</p>
      <h2 id="system-explore-title">
        <span><span data-explore-line>Od pierwszego sygnału.</span></span>
        <span><span data-explore-line>Do pracy wykonanej</span></span>
        <span><span data-explore-line>pod pełną kontrolą.</span></span>
      </h2>
      <p class="system-explore__note" data-scramble>
        Projektujemy warstwy, które rozmawiają, rozumieją, działają i stale uczą się realiów Twojej firmy.
      </p>
    </div>

    <div class="system-explore__progress" aria-hidden="true">
      <span>01</span>
      <i data-explore-progress></i>
      <span>04</span>
    </div>
  </div>
</section>
