<section class="founders" data-founders aria-labelledby="founders-title">
  <div class="founders__shell">
    <header class="founders__header" data-founder-copy>
      <p class="founders__eyebrow">/ O nas</p>
      <h2 id="founders-title">Dwie perspektywy.<br /><em>Jedna odpowiedzialność.</em></h2>
      <p class="founders__intro">
        Strategia i technologia pracują u nas przy jednym stole — od pierwszej diagnozy po rozwój działającego systemu.
      </p>
    </header>

    <div class="founders__grid">
      <article class="founder-card founder-card--lime" data-founder-card>
        <div class="founder-card__visual">
          <div
            class="founder-card__portrait"
            role="img"
            aria-label="Neutralny placeholder portretu Pawła"
          >
            <span class="founder-card__index" aria-hidden="true">01 / SFAI</span>
            <span class="founder-card__monogram" aria-hidden="true">PP</span>
            <span class="founder-card__caption" aria-hidden="true">Co-founder</span>
          </div>
          <a
            class="founder-card__linkedin"
            href="https://www.linkedin.com/company/simple-fast-ai/"
            target="_blank"
            rel="noreferrer"
            data-profile-placeholder="company-fallback"
            aria-label="LinkedIn SimpleFast.ai — tymczasowo do podmiany na prywatny profil Pawła"
          >
            <span>LinkedIn</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="founder-card__details">
          <div>
            <p class="founder-card__role">Co-founder / Architekt AI full-stack</p>
            <h3>Paweł Pieloch</h3>
          </div>
          <p class="founder-card__bio">
            Projektuje i buduje rozwiązania end to end: strony, agentów, automatyzacje, chatboty, voiceboty i aplikacje.
          </p>
        </div>
      </article>

      <article class="founder-card founder-card--blue" data-founder-card>
        <div class="founder-card__visual">
          <div
            class="founder-card__portrait"
            role="img"
            aria-label="Neutralny placeholder portretu Marcina"
          >
            <span class="founder-card__index" aria-hidden="true">02 / SFAI</span>
            <span class="founder-card__monogram" aria-hidden="true">MK</span>
            <span class="founder-card__caption" aria-hidden="true">Co-founder</span>
          </div>
          <a
            class="founder-card__linkedin"
            href="https://www.linkedin.com/company/simple-fast-ai/"
            target="_blank"
            rel="noreferrer"
            data-profile-placeholder="company-fallback"
            aria-label="LinkedIn SimpleFast.ai — tymczasowo do podmiany na prywatny profil Marcina"
          >
            <span>LinkedIn</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="founder-card__details">
          <div>
            <p class="founder-card__role">Co-founder / Relacja i delivery</p>
            <h3>Marcin Karpeta</h3>
          </div>
          <p class="founder-card__bio">
            Spina relację z klientem, dowiezienie projektu i opiekę po wdrożeniu — od pierwszej rozmowy po rozwój systemu.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .founders {
    overflow: hidden;
    padding: clamp(6.5rem, 11vw, 11rem) 0;
    background:
      radial-gradient(circle at 88% 8%, rgba(99, 112, 255, 0.09), transparent 28rem),
      radial-gradient(circle at 8% 92%, rgba(223, 255, 63, 0.06), transparent 24rem),
      var(--ink, #0d0e0e);
    color: var(--white, #f7f7f2);
  }

  .founders__shell {
    width: var(--shell, min(100% - 40px, 1540px));
    margin-inline: auto;
  }

  .founders__header {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(16rem, 3fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(3.5rem, 7vw, 7rem);
  }

  .founders__eyebrow {
    grid-column: 1 / -1;
    margin: 0 0 clamp(0.75rem, 2vw, 1.75rem);
    color: var(--muted, #969b98);
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .founders__header h2 {
    margin: 0;
    font-family: var(--font-display, sans-serif);
    font-size: clamp(3.4rem, 7.1vw, 8.1rem);
    font-weight: 520;
    letter-spacing: -0.07em;
    line-height: 0.86;
  }

  .founders__header h2 em {
    color: var(--lime, #dfff3f);
    font-family: Georgia, serif;
    font-weight: 400;
  }

  .founders__intro {
    max-width: 29rem;
    margin: 0;
    color: #b7bbb7;
    font-size: clamp(1rem, 1.3vw, 1.22rem);
    line-height: 1.48;
  }

  .founders__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2.2vw, 2.25rem);
  }

  .founder-card {
    min-width: 0;
  }

  .founders[data-enhanced='true'] [data-founder-copy],
  .founders[data-enhanced='true'] [data-founder-card] {
    opacity: 0;
    filter: blur(10px);
    transform: translateY(44px);
    transition:
      opacity 0.85s ease,
      filter 1.05s var(--ease-out, cubic-bezier(.16, 1, .3, 1)),
      transform 1.05s var(--ease-out, cubic-bezier(.16, 1, .3, 1));
  }

  .founders[data-enhanced='true'] [data-founder-card]:nth-child(2) {
    transition-delay: 0.14s;
  }

  .founders[data-enhanced='true'].is-visible [data-founder-copy],
  .founders[data-enhanced='true'].is-visible [data-founder-card] {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  .founder-card__visual {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #171918;
    isolation: isolate;
  }

  .founder-card__visual::after {
    position: absolute;
    z-index: 2;
    inset: 0;
    border: 1px solid rgba(247, 247, 242, 0.14);
    content: '';
    pointer-events: none;
  }

  .founder-card__portrait {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      linear-gradient(115deg, transparent 48%, rgba(255, 255, 255, 0.055) 48.2%, transparent 48.55%),
      repeating-linear-gradient(90deg, transparent 0 12.4%, rgba(255, 255, 255, 0.035) 12.5% 12.65%),
      radial-gradient(circle at 50% 43%, rgba(247, 247, 242, 0.08), transparent 34%),
      linear-gradient(145deg, #272a29, #101111 58%, #1c1f1e);
    transition:
      filter 0.7s var(--ease-out, cubic-bezier(.16, 1, .3, 1)),
      transform 0.9s var(--ease-out, cubic-bezier(.16, 1, .3, 1));
  }

  .founder-card--blue .founder-card__portrait {
    background:
      linear-gradient(64deg, transparent 47.8%, rgba(99, 112, 255, 0.26) 48%, transparent 48.35%),
      repeating-linear-gradient(0deg, transparent 0 10.8%, rgba(255, 255, 255, 0.03) 10.9% 11.05%),
      radial-gradient(circle at 52% 42%, rgba(99, 112, 255, 0.15), transparent 34%),
      linear-gradient(215deg, #222528, #101111 58%, #1a1d22);
  }

  .founder-card__portrait::before,
  .founder-card__portrait::after {
    position: absolute;
    border: 1px solid rgba(247, 247, 242, 0.1);
    border-radius: 50%;
    content: '';
  }

  .founder-card__portrait::before {
    width: 56%;
    aspect-ratio: 1;
    top: 18%;
    left: 22%;
  }

  .founder-card__portrait::after {
    width: 78%;
    aspect-ratio: 1;
    right: -20%;
    bottom: -20%;
  }

  .founder-card__index,
  .founder-card__caption {
    position: absolute;
    z-index: 1;
    color: rgba(247, 247, 242, 0.48);
    font-family: var(--font-mono, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .founder-card__index {
    top: 1.5rem;
    left: 1.5rem;
  }

  .founder-card__caption {
    right: 1.5rem;
    bottom: 1.5rem;
  }

  .founder-card__monogram {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    color: rgba(247, 247, 242, 0.88);
    font-family: var(--font-display, sans-serif);
    font-size: clamp(11rem, 25vw, 27rem);
    font-weight: 500;
    letter-spacing: -0.12em;
    line-height: 0.7;
    transform: translate(-53%, -45%);
  }

  .founder-card--lime .founder-card__monogram {
    text-shadow: 0.018em 0.018em 0 var(--lime, #dfff3f);
  }

  .founder-card--blue .founder-card__monogram {
    text-shadow: -0.018em 0.018em 0 var(--blue, #6370ff);
  }

  .founder-card__linkedin {
    position: absolute;
    z-index: 4;
    top: 50%;
    left: 50%;
    display: inline-flex;
    min-width: 10.5rem;
    min-height: 3.6rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border: 1px solid rgba(247, 247, 242, 0.64);
    border-radius: 999px;
    padding: 0 1.3rem;
    background: rgba(13, 14, 14, 0.72);
    color: var(--white, #f7f7f2);
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    opacity: 0;
    text-transform: uppercase;
    transform: translate(-50%, calc(-50% + 1rem));
    transition:
      opacity 0.42s ease,
      transform 0.62s var(--ease-out, cubic-bezier(.16, 1, .3, 1)),
      border-color 0.25s,
      background 0.25s,
      color 0.25s;
  }

  .founder-card__linkedin:hover,
  .founder-card__linkedin:focus-visible {
    border-color: var(--lime, #dfff3f);
    background: var(--lime, #dfff3f);
    color: var(--ink, #0d0e0e);
    outline: none;
  }

  .founder-card__visual:hover .founder-card__portrait,
  .founder-card__visual:focus-within .founder-card__portrait {
    filter: blur(13px) brightness(0.52);
    transform: scale(1.055);
  }

  .founder-card__visual:hover .founder-card__linkedin,
  .founder-card__visual:focus-within .founder-card__linkedin {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  .founder-card__details {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(14rem, 0.7fr);
    gap: 2rem;
    align-items: end;
    border-top: 1px solid rgba(247, 247, 242, 0.18);
    padding: 1.45rem 0 0;
  }

  .founder-card__role {
    margin: 0 0 0.55rem;
    color: var(--muted, #969b98);
    font-family: var(--font-mono, monospace);
    font-size: 0.62rem;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .founder-card__details h3 {
    margin: 0;
    font-size: clamp(2.3rem, 4.2vw, 4.5rem);
    font-weight: 520;
    letter-spacing: -0.065em;
    line-height: 0.92;
  }

  .founder-card__bio {
    margin: 0;
    color: #aeb2ae;
    font-size: 0.96rem;
    line-height: 1.5;
  }

  @media (max-width: 980px) {
    .founders__header {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .founders__eyebrow {
      grid-column: auto;
      margin-bottom: 0;
    }

    .founders__intro {
      max-width: 36rem;
    }

    .founder-card__details {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 720px) {
    .founders {
      padding: 5.5rem 0;
    }

    .founders__shell {
      width: min(100% - 1.5rem, 1540px);
    }

    .founders__header h2 {
      font-size: clamp(3rem, 14vw, 5.4rem);
    }

    .founders__grid {
      grid-template-columns: 1fr;
      gap: 4.5rem;
    }

    .founder-card__visual {
      aspect-ratio: 5 / 6;
    }

    .founder-card__monogram {
      font-size: clamp(13rem, 58vw, 22rem);
    }
  }

  @media (hover: none) {
    .founder-card__linkedin {
      top: auto;
      right: 1rem;
      bottom: 1rem;
      left: auto;
      min-width: 9.25rem;
      min-height: 3.2rem;
      opacity: 1;
      transform: none;
    }

    .founder-card__caption {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .founders[data-enhanced='true'] [data-founder-copy],
    .founders[data-enhanced='true'] [data-founder-card] {
      opacity: 1;
      filter: none;
      transform: none;
      transition: none;
    }

    .founder-card__portrait,
    .founder-card__linkedin {
      transition: none;
    }

    .founder-card__visual:hover .founder-card__portrait,
    .founder-card__visual:focus-within .founder-card__portrait {
      transform: none;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-founders]').forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.foundersBound) return;
    root.dataset.foundersBound = 'true';
    root.dataset.enhanced = 'true';

    const show = () => root.classList.add('is-visible');
    if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      show();
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      if (!entries.some((entry) => entry.isIntersecting)) return;
      show();
      observer.disconnect();
    }, { threshold: 0.16 });

    observer.observe(root);
  });
</script>
