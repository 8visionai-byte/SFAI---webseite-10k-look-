---
import { Image } from 'astro:assets';
import valueArchitectureImage from '../assets/generated/v3/value-architecture.png';
import aiCareObservatoryImage from '../assets/generated/v3/ai-care-observatory.png';
import voicebotImage from '../assets/generated/v3/voicebot-robot.png';
import chatbotKnowledgeImage from '../assets/generated/v3/chatbot-knowledge.png';
import seoAiCitationsImage from '../assets/generated/v3/seo-ai-citations.png';
import aiAgentControlImage from '../assets/generated/v3/ai-agent-control.png';
import processAutomationImage from '../assets/generated/v3/process-automation.png';
import humanAiTouchImage from '../assets/generated/v3/human-ai-touch.png';

const streams = [
  {
    index: '01',
    title: 'Realizacje',
    meta: 'Systemy osadzone w procesie',
    description: 'Voiceboty, agenci i automatyzacje projektowane wokół konkretnego zadania, kontroli i wyniku.',
    images: [
      {
        src: voicebotImage,
        alt: 'Profesjonalny voicebot AI przygotowany do obsługi rozmów i rezerwacji',
      },
      {
        src: aiAgentControlImage,
        alt: 'Agent AI przeprowadzający zadanie od sygnału do kontrolowanego działania',
      },
      {
        src: processAutomationImage,
        alt: 'Automatyzacja łącząca dane i narzędzia firmy w jeden przepływ',
      },
    ],
  },
  {
    index: '02',
    title: 'Publikacje',
    meta: 'Wiedza bez hype’u',
    description: 'Praktyczne materiały o widoczności w AI, jakości wiedzy i wyborze procesów, które warto automatyzować.',
    images: [
      {
        src: seoAiCitationsImage,
        alt: 'Źródła treści prowadzące do widoczności marki w odpowiedziach AI',
      },
      {
        src: chatbotKnowledgeImage,
        alt: 'Kontrolowana baza wiedzy wykorzystywana przez chatbota AI',
      },
    ],
  },
  {
    index: '03',
    title: 'Kompetencje',
    meta: 'Strategia / design / delivery',
    description: 'Łączymy architekturę wartości, doświadczenie człowieka i techniczne wdrożenie w jeden odpowiedzialny proces.',
    images: [
      {
        src: humanAiTouchImage,
        alt: 'Współpraca człowieka z technologią AI przedstawiona jako precyzyjny interfejs',
      },
      {
        src: valueArchitectureImage,
        alt: 'Architektura wartości AI porządkująca priorytety i decyzje wdrożeniowe',
      },
      {
        src: chatbotKnowledgeImage,
        alt: 'Warstwa wiedzy firmy przygotowana do bezpiecznej pracy systemu AI',
      },
    ],
  },
  {
    index: '04',
    title: 'Systemy w opiece',
    meta: 'Monitoring / rozwój / ciągłość',
    description: 'Po uruchomieniu pilnujemy jakości, aktualizujemy wiedzę i rozwijamy integracje wraz ze zmianami w firmie.',
    images: [
      {
        src: aiCareObservatoryImage,
        alt: 'Obserwatorium monitorujące jakość i ciągłość działania systemów AI',
      },
      {
        src: aiAgentControlImage,
        alt: 'Panel kontroli działań agenta AI z wyraźnymi granicami odpowiedzialności',
      },
      {
        src: processAutomationImage,
        alt: 'Monitorowany przepływ automatyzacji pomiędzy systemami firmy',
      },
    ],
  },
];
---

<section class="proof-stream" data-proof-stream aria-labelledby="proof-stream-title">
  <div class="proof-stream__shell">
    <header class="proof-stream__header">
      <p class="proof-stream__eyebrow">/ Praktyka SimpleFast.ai</p>
      <h2 id="proof-stream-title">Budujemy. Opisujemy. Utrzymujemy.</h2>
      <p>Bez dekoracyjnych nagród i pustych odznaczeń. Pokazujemy obszary pracy, za które bierzemy odpowiedzialność.</p>
    </header>

    <div class="proof-stream__stage">
      <div class="proof-stream__media" aria-live="off">
        {streams.map((stream, streamIndex) => (
          <div
            class:list={['proof-stream__panel', streamIndex === 0 && 'is-active']}
            id={`proof-stream-panel-${streamIndex + 1}`}
            role="tabpanel"
            aria-labelledby={`proof-stream-tab-${streamIndex + 1}`}
            aria-hidden={streamIndex === 0 ? 'false' : 'true'}
            data-proof-panel
            style={`--panel-count:${stream.images.length}`}
          >
            {stream.images.map((image, imageIndex) => (
              <figure class="proof-stream__asset" style={`--asset-index:${imageIndex}`}>
                <Image
                  src={image.src}
                  alt={image.alt}
                  widths={[480, 760, 1080, 1440]}
                  sizes="(max-width: 760px) 48vw, 31vw"
                  format="webp"
                  quality={84}
                  loading="lazy"
                />
              </figure>
            ))}
          </div>
        ))}
      </div>

      <div class="proof-stream__list" role="tablist" aria-label="Obszary praktyki SimpleFast.ai" aria-orientation="vertical">
        {streams.map((stream, streamIndex) => (
          <button
            class:list={['proof-stream__row', streamIndex === 0 && 'is-active']}
            id={`proof-stream-tab-${streamIndex + 1}`}
            type="button"
            role="tab"
            aria-selected={streamIndex === 0 ? 'true' : 'false'}
            aria-controls={`proof-stream-panel-${streamIndex + 1}`}
            tabindex={streamIndex === 0 ? 0 : -1}
            data-proof-tab
            data-proof-index={streamIndex}
          >
            <span class="proof-stream__number">{stream.index}</span>
            <span class="proof-stream__title">{stream.title}</span>
            <span class="proof-stream__meta">{stream.meta}</span>
            <span class="proof-stream__arrow" aria-hidden="true">↗</span>
            <span class="proof-stream__description">{stream.description}</span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .proof-stream {
    --proof-ink: #090a0a;
    --proof-white: #f0f2ee;
    --proof-muted: rgba(240, 242, 238, 0.5);
    --proof-line: rgba(240, 242, 238, 0.15);
    --proof-lime: #c8ff45;
    position: relative;
    overflow: hidden;
    padding: clamp(110px, 12vw, 190px) 0;
    background: var(--proof-ink);
    color: var(--proof-white);
    isolation: isolate;
  }

  .proof-stream::before {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 50%, rgba(49, 89, 255, 0.075), transparent 42%),
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 100% 100%, 100% 9.5vh;
    content: '';
    opacity: 0.7;
    pointer-events: none;
  }

  .proof-stream__shell {
    position: relative;
    z-index: 1;
    width: min(calc(100% - 40px), 1540px);
    margin: 0 auto;
  }

  .proof-stream__header {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 20px;
    align-items: end;
    margin-bottom: clamp(64px, 8vw, 112px);
  }

  .proof-stream__eyebrow {
    grid-column: 1 / 3;
    align-self: start;
    padding-top: 0.55rem;
    color: var(--proof-muted);
    font-family: var(--font-mono, monospace);
    font-size: 0.58rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .proof-stream__header h2 {
    grid-column: 3 / 10;
    max-width: 960px;
    font-size: clamp(3.6rem, 7.4vw, 8.6rem);
    font-weight: 560;
    line-height: 0.84;
    letter-spacing: -0.075em;
  }

  .proof-stream__header > p:last-child {
    grid-column: 10 / -1;
    max-width: 390px;
    color: rgba(240, 242, 238, 0.64);
    font-size: 0.98rem;
    line-height: 1.42;
  }

  .proof-stream__stage {
    position: relative;
    min-height: clamp(650px, 54vw, 850px);
  }

  .proof-stream__media {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    width: 112vw;
    height: clamp(250px, 25vw, 420px);
    overflow: hidden;
    pointer-events: none;
    transform: translate(-50%, -50%);
  }

  .proof-stream__media::before,
  .proof-stream__media::after {
    position: absolute;
    z-index: 8;
    top: 0;
    bottom: 0;
    width: 15vw;
    content: '';
    pointer-events: none;
  }

  .proof-stream__media::before {
    left: 0;
    background: linear-gradient(90deg, var(--proof-ink), transparent);
  }

  .proof-stream__media::after {
    right: 0;
    background: linear-gradient(-90deg, var(--proof-ink), transparent);
  }

  .proof-stream__panel {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(var(--panel-count), minmax(0, 1fr));
    gap: clamp(10px, 1.4vw, 24px);
    padding-inline: 5vw;
    visibility: hidden;
    opacity: 0;
  }

  .proof-stream__panel.is-entering,
  .proof-stream__panel.is-active,
  .proof-stream__panel.is-exiting {
    visibility: visible;
    opacity: 1;
  }

  .proof-stream__panel.is-active { z-index: 3; }
  .proof-stream__panel.is-exiting { z-index: 2; }

  .proof-stream__asset {
    position: relative;
    height: 100%;
    overflow: hidden;
    margin: 0;
    opacity: 0;
    background: #121414;
    transform: translateX(-8vw);
    transition:
      opacity 0.34s calc(var(--asset-index) * 55ms) linear,
      transform 0.68s calc(0.58s + var(--asset-index) * 55ms) cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proof-stream__asset:nth-child(2) { transform: translate(-8vw, -7%); }
  .proof-stream__asset:nth-child(3) { transform: translate(-8vw, 8%); }

  .proof-stream__asset::before,
  .proof-stream__asset::after {
    position: absolute;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .proof-stream__asset::before {
    z-index: 3;
    background: linear-gradient(90deg, #090a0a 0%, #101212 72%, rgba(16, 18, 18, 0.96) 100%);
    transform: scaleX(1);
    transform-origin: right center;
    transition: transform 0.52s calc(var(--asset-index) * 55ms) cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .proof-stream__asset::after {
    z-index: 2;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(135deg, transparent 58%, rgba(255, 255, 255, 0.09));
  }

  .proof-stream__asset img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(10px) brightness(0.4) saturate(0.38) contrast(0.78);
    transform: scale(1.055);
    transition:
      filter 0.34s 0.34s cubic-bezier(0.22, 0.72, 0, 1),
      transform 0.72s 0.62s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proof-stream__panel.is-active .proof-stream__asset {
    opacity: 1;
    transform: translate(0, 0);
  }

  .proof-stream__panel.is-active .proof-stream__asset::before { transform: scaleX(0); }

  .proof-stream__panel.is-active .proof-stream__asset img {
    filter: blur(0) brightness(1) saturate(0.9) contrast(1.06);
    transform: scale(1);
  }

  .proof-stream__panel.is-exiting .proof-stream__asset {
    opacity: 0;
    transform: translateX(10vw);
    transition:
      transform 0.5s calc(var(--asset-index) * 32ms) cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.28s calc(0.16s + var(--asset-index) * 32ms) ease;
  }

  .proof-stream__panel.is-exiting .proof-stream__asset::before {
    transform: scaleX(1);
    transform-origin: left center;
    transition-delay: calc(0.18s + var(--asset-index) * 32ms);
  }

  .proof-stream__panel.is-exiting .proof-stream__asset img {
    filter: blur(8px) brightness(0.52) saturate(0.48) contrast(0.82);
    transform: scale(1.025);
    transition: filter 0.32s ease, transform 0.42s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proof-stream__list {
    position: relative;
    z-index: 5;
    border-top: 1px solid var(--proof-line);
  }

  .proof-stream__row {
    display: grid;
    width: 100%;
    min-height: clamp(132px, 11.5vw, 174px);
    grid-template-columns: 70px minmax(250px, 1.4fr) minmax(240px, 1fr) 32px;
    gap: 22px;
    align-items: center;
    border: 0;
    border-bottom: 1px solid var(--proof-line);
    border-radius: 0;
    padding: 20px 0;
    background: rgba(9, 10, 10, 0.2);
    color: inherit;
    opacity: 0.25;
    cursor: pointer;
    text-align: left;
    transition: opacity 0.38s ease, background 0.38s ease;
  }

  .proof-stream__row.is-active,
  .proof-stream__row:hover,
  .proof-stream__row:focus-visible {
    background: rgba(9, 10, 10, 0.54);
    opacity: 1;
  }

  .proof-stream__row:focus-visible {
    outline: 1px solid var(--proof-lime);
    outline-offset: 4px;
  }

  .proof-stream__number,
  .proof-stream__meta {
    color: rgba(240, 242, 238, 0.66);
    font-family: var(--font-mono, monospace);
    font-size: 0.57rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .proof-stream__title {
    font-size: clamp(2.4rem, 4.6vw, 5.5rem);
    font-weight: 560;
    line-height: 0.88;
    letter-spacing: -0.06em;
    transition: transform 0.48s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proof-stream__row:is(.is-active, :hover, :focus-visible) .proof-stream__title { transform: translateX(10px); }

  .proof-stream__meta { justify-self: end; }

  .proof-stream__arrow {
    color: var(--proof-lime);
    font-size: 1.3rem;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .proof-stream__row.is-active .proof-stream__arrow { transform: rotate(45deg); }

  .proof-stream__description {
    grid-column: 2 / 4;
    align-self: start;
    max-width: 720px;
    margin-top: -22px;
    padding-bottom: 5px;
    color: rgba(240, 242, 238, 0.62);
    font-size: 0.9rem;
    line-height: 1.35;
  }

  @media (max-width: 900px) {
    .proof-stream__header { display: block; }
    .proof-stream__header h2 { margin-top: 28px; }
    .proof-stream__header > p:last-child { max-width: 520px; margin-top: 26px; }
    .proof-stream__row { grid-template-columns: 48px minmax(0, 1fr) auto; }
    .proof-stream__meta { grid-column: 2; grid-row: 2; justify-self: start; }
    .proof-stream__arrow { grid-column: 3; grid-row: 1; }
    .proof-stream__description { grid-column: 2 / -1; grid-row: 3; margin-top: 0; }
  }

  @media (max-width: 760px) {
    .proof-stream { padding: 96px 0; }
    .proof-stream__shell { width: calc(100% - 28px); }
    .proof-stream__header { margin-bottom: 52px; }
    .proof-stream__header h2 { font-size: clamp(3.5rem, 15vw, 5.7rem); }
    .proof-stream__stage { display: flex; min-height: 0; flex-direction: column; }
    .proof-stream__media {
      position: relative;
      top: auto;
      left: auto;
      order: 1;
      width: calc(100% + 28px);
      height: 292px;
      margin-left: -14px;
      margin-bottom: 42px;
      transform: none;
    }
    .proof-stream__media::before,
    .proof-stream__media::after { width: 32px; }
    .proof-stream__panel { gap: 8px; padding-inline: 14px; }
    .proof-stream__asset:nth-child(2),
    .proof-stream__asset:nth-child(3) { transform: translateX(-8vw); }
    .proof-stream__panel.is-active .proof-stream__asset { transform: none; }
    .proof-stream__list { order: 2; }
    .proof-stream__row {
      min-height: 122px;
      grid-template-columns: 34px minmax(0, 1fr) 24px;
      gap: 10px;
      padding: 19px 0;
      opacity: 0.42;
    }
    .proof-stream__row:hover { background: rgba(9, 10, 10, 0.2); }
    .proof-stream__row.is-active,
    .proof-stream__row:focus-visible { background: rgba(9, 10, 10, 0.56); opacity: 1; }
    .proof-stream__row:is(.is-active, :hover, :focus-visible) .proof-stream__title { transform: translateX(6px); }
    .proof-stream__number { font-size: 0.49rem; }
    .proof-stream__title { font-size: clamp(2.2rem, 11vw, 3.8rem); }
    .proof-stream__meta { font-size: 0.48rem; }
    .proof-stream__description { font-size: 0.78rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .proof-stream *,
    .proof-stream *::before,
    .proof-stream *::after {
      scroll-behavior: auto !important;
      animation: none !important;
      transition: none !important;
    }

    .proof-stream__panel.is-exiting { visibility: hidden; opacity: 0; }
    .proof-stream__panel.is-active .proof-stream__asset {
      opacity: 1;
      transform: none;
    }
    .proof-stream__panel.is-active .proof-stream__asset::before { transform: scaleX(0); }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-proof-stream]').forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.proofBound) return;
    root.dataset.proofBound = 'true';

    const tabs = [...root.querySelectorAll('[data-proof-tab]')];
    const panels = [...root.querySelectorAll('[data-proof-panel]')];
    if (!tabs.length || tabs.length !== panels.length) return;

    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const exitTimers = new WeakMap();
    let activeIndex = Math.max(0, tabs.findIndex((tab) => tab.getAttribute('aria-selected') === 'true'));

    const clearExit = (panel) => {
      const timer = exitTimers.get(panel);
      if (timer) window.clearTimeout(timer);
      exitTimers.delete(panel);
      panel.classList.remove('is-exiting');
    };

    const activate = (nextIndex) => {
      if (nextIndex === activeIndex || !tabs[nextIndex] || !panels[nextIndex]) return;

      const previousPanel = panels[activeIndex];
      const nextPanel = panels[nextIndex];
      clearExit(nextPanel);

      tabs.forEach((tab, index) => {
        const selected = index === nextIndex;
        tab.classList.toggle('is-active', selected);
        tab.setAttribute('aria-selected', String(selected));
        tab.tabIndex = selected ? 0 : -1;
      });

      previousPanel.setAttribute('aria-hidden', 'true');
      previousPanel.classList.remove('is-entering', 'is-active');

      if (reducedMotion.matches) {
        clearExit(previousPanel);
      } else {
        previousPanel.classList.add('is-exiting');
        const timer = window.setTimeout(() => clearExit(previousPanel), 980);
        exitTimers.set(previousPanel, timer);
      }

      nextPanel.setAttribute('aria-hidden', 'false');
      nextPanel.classList.remove('is-active');
      nextPanel.classList.add('is-entering');
      void nextPanel.offsetWidth;
      nextPanel.classList.add('is-active');
      nextPanel.classList.remove('is-entering');
      activeIndex = nextIndex;
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('focus', () => activate(index));
      tab.addEventListener('click', () => activate(index));
      tab.addEventListener('pointerenter', () => {
        if (finePointer.matches) activate(index);
      });
      tab.addEventListener('keydown', (event) => {
        let nextIndex = null;
        if (event.key === 'ArrowDown' || event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
        if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabs.length - 1;
        if (nextIndex === null) return;
        event.preventDefault();
        tabs[nextIndex].focus();
      });
    });
  });
</script>
