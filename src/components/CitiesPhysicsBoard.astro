---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  intro?: string;
  cities?: string[];
}

// Realne, przybliżone liczby mieszkańców (GUS, w tysiącach).
// Powierzchnia bańki jest proporcjonalna do populacji (promień ~ sqrt(populacja)).
const population: Record<string, number> = {
  'Warszawa': 1860, 'Kraków': 800, 'Łódź': 660, 'Wrocław': 674, 'Poznań': 540,
  'Gdańsk': 486, 'Szczecin': 391, 'Bydgoszcz': 330, 'Lublin': 331, 'Białystok': 295,
  'Katowice': 285, 'Gdynia': 240, 'Częstochowa': 214, 'Radom': 200, 'Sosnowiec': 190,
  'Toruń': 196, 'Kielce': 190, 'Gliwice': 174, 'Zabrze': 168, 'Bytom': 156,
  'Olsztyn': 170, 'Bielsko-Biała': 168, 'Rzeszów': 197, 'Ruda Śląska': 132, 'Rybnik': 132,
  'Tychy': 126, 'Dąbrowa Górnicza': 114, 'Płock': 116, 'Elbląg': 117, 'Opole': 127,
  'Gorzów Wielkopolski': 122, 'Wałbrzych': 103, 'Włocławek': 106, 'Zielona Góra': 141,
  'Tarnów': 105, 'Chorzów': 105, 'Koszalin': 105, 'Kalisz': 96, 'Legnica': 97,
  'Grudziądz': 92, 'Słupsk': 88, 'Jaworzno': 88, 'Jastrzębie-Zdrój': 84, 'Nowy Sącz': 83,
  'Jelenia Góra': 76, 'Konin': 71, 'Siedlce': 77, 'Mysłowice': 74, 'Piła': 71,
  'Ostrów Wielkopolski': 72, 'Lubin': 71, 'Suwałki': 69, 'Stargard': 66, 'Gniezno': 67,
  'Piotrków Trybunalski': 70, 'Pabianice': 62, 'Inowrocław': 71, 'Ostrowiec Świętokrzyski': 62,
  'Siemianowice Śląskie': 63, 'Głogów': 66, 'Zamość': 62, 'Leszno': 62, 'Chełm': 60,
  'Łomża': 62, 'Żory': 61, 'Tarnowskie Góry': 61, 'Tomaszów Mazowiecki': 60, 'Ełk': 62,
  'Mielec': 60, 'Przemyśl': 58, 'Stalowa Wola': 58, 'Tczew': 59, 'Kędzierzyn-Koźle': 58,
  'Bełchatów': 56, 'Świdnica': 55, 'Będzin': 55, 'Zgierz': 55, 'Piekary Śląskie': 54,
  'Rumia': 50, 'Legionowo': 54, 'Piaseczno': 48, 'Biała Podlaska': 57,
};

const DEFAULT_POP = 45;
const ACCENT_THRESHOLD = 480; // limonka dla największych miast (>= ~480 tys.)
const populationOf = (name: string) => population[name] ?? DEFAULT_POP;

const defaultCities = [
  'Warszawa',
  'Kraków',
  'Wrocław',
  'Łódź',
  'Poznań',
  'Gdańsk',
  'Szczecin',
  'Lublin',
  'Bydgoszcz',
  'Białystok',
  'Katowice',
  'Gdynia',
  'Częstochowa',
  'Rzeszów',
  'Toruń',
  'Radom',
  'Sosnowiec',
  'Kielce',
  'Gliwice',
  'Olsztyn',
  'Bielsko-Biała',
  'Zabrze',
  'Bytom',
  'Zielona Góra',
  'Rybnik',
  'Ruda Śląska',
  'Opole',
  'Tychy',
  'Gorzów Wielkopolski',
  'Dąbrowa Górnicza',
  'Elbląg',
  'Płock',
  'Koszalin',
  'Tarnów',
  'Chorzów',
  'Włocławek',
  'Wałbrzych',
  'Kalisz',
  'Legnica',
  'Grudziądz',
  'Jaworzno',
  'Słupsk',
  'Jastrzębie-Zdrój',
  'Nowy Sącz',
  'Siedlce',
  'Jelenia Góra',
  'Mysłowice',
  'Piła',
  'Ostrów Wielkopolski',
  'Suwałki',
  'Lubin',
  'Pruszków',
  'Inowrocław',
  'Stargard',
  'Piotrków Trybunalski',
  'Konin',
  'Siemianowice Śląskie',
  'Gniezno',
  'Żory',
  'Tarnowskie Góry',
  'Głogów',
  'Ostrowiec Świętokrzyski',
  'Pabianice',
  'Łomża',
  'Ełk',
  'Leszno',
  'Zamość',
  'Tomaszów Mazowiecki',
  'Mielec',
  'Tczew',
  'Chełm',
  'Przemyśl',
  'Rumia',
  'Stalowa Wola',
  'Biała Podlaska',
  'Kędzierzyn-Koźle',
  'Będzin',
  'Zgierz',
  'Legionowo',
  'Piaseczno',
  'Świdnica',
  'Piekary Śląskie',
  'Bełchatów',
];

const {
  id = 'cities-physics',
  eyebrow = '/ SFAI / POLSKA',
  title = 'Jeden system.',
  titleAccent = 'Cała Polska.',
  intro = 'Diagnozę, wdrożenie i opiekę prowadzimy niezależnie od kodu pocztowego. Technologia trafia tam, gdzie istnieje realny proces do usprawnienia.',
  cities: suppliedCities,
} = Astro.props;

const cities = suppliedCities?.length ? suppliedCities : defaultCities;
const titleId = `${id}-title`;
const instructionId = `${id}-instruction`;
---

<section
  class="cities-physics"
  id={id}
  data-cities-physics
  data-testid="cities-physics-board"
  data-reduced="false"
  data-physics-ready="false"
  aria-labelledby={titleId}
>
  <div class="cities-physics__shell">
    <header class="cities-physics__header">
      <p class="cities-physics__eyebrow">{eyebrow}</p>
      <h2 id={titleId}>{title}<br /><em>{titleAccent}</em></h2>
      <div class="cities-physics__intro">
        <p data-scramble>{intro}</p>
        <span aria-hidden="true">PL / 01—16</span>
      </div>
    </header>

    <div class="cities-physics__space" aria-hidden="true"></div>
  </div>

  <p class="cities-physics__instruction" id={instructionId}>
    Przeciągnij dowolne miasto. Banieczki żyją, odbijają się od siebie i od krawędzi.
  </p>

  <ul
    class="cities-physics__world"
    data-city-world
    data-testid="cities-physics-stage"
    aria-label="Duże polskie miasta objęte zdalną współpracą SimpleFast.ai"
    aria-describedby={instructionId}
  >
    {cities.map((city, index) => (
      <li
        class="cities-physics__bubble"
        data-city-tile
        data-city-index={index}
        data-city={city}
        data-pop={populationOf(city)}
        data-accent={populationOf(city) >= ACCENT_THRESHOLD ? 'true' : 'false'}
      >
        <span>{city}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .cities-physics {
    --cities-cobalt: #1738d1;
    --cities-cobalt-dark: #1028aa;
    --cities-cobalt-deep: #091858;
    --cities-lime: var(--lime, #dfff3f);
    --cities-white: #f6f7f1;
    position: relative;
    overflow: hidden;
    padding: clamp(6rem, 10vw, 10rem) 0 clamp(2rem, 4vw, 4rem);
    background:
      radial-gradient(circle at 84% 2%, rgba(143, 171, 255, 0.3), transparent 25rem),
      linear-gradient(145deg, var(--cities-cobalt) 0%, #1534c8 52%, var(--cities-cobalt-dark) 100%);
    color: var(--cities-white);
    isolation: isolate;
  }

  .cities-physics::before {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
    background-position: center;
    background-size: clamp(4rem, 7vw, 7.5rem) clamp(4rem, 7vw, 7.5rem);
    content: '';
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.74), transparent 85%);
    opacity: 0.42;
    pointer-events: none;
  }

  .cities-physics::after {
    position: absolute;
    top: -22rem;
    left: 52%;
    width: min(62rem, 82vw);
    aspect-ratio: 1;
    border: 1px solid rgba(223, 255, 63, 0.15);
    border-radius: 50%;
    box-shadow:
      0 0 0 7rem rgba(255, 255, 255, 0.018),
      0 0 0 15rem rgba(255, 255, 255, 0.012);
    content: '';
    pointer-events: none;
    transform: translateX(-50%);
  }

  /* Tekst NAD banieczkami: wyższy z-index, a pointer-events: none
     przepuszcza drag do warstwy fizyki (w nagłówku nie ma nic klikalnego). */
  .cities-physics__shell {
    position: relative;
    z-index: 2;
    width: min(calc(100% - 40px), 1540px);
    margin-inline: auto;
    pointer-events: none;
  }

  .cities-physics__header {
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(18rem, 3fr);
    gap: clamp(2rem, 6vw, 8rem);
    align-items: end;
    margin-bottom: clamp(3.5rem, 7vw, 7rem);
  }

  .cities-physics__eyebrow {
    grid-column: 1 / -1;
    margin: 0 0 clamp(0.5rem, 1.4vw, 1.2rem);
    color: var(--cities-lime);
    font-family: var(--font-mono, monospace);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cities-physics__header h2 {
    max-width: 12ch;
    margin: 0;
    font-family: var(--font-display, sans-serif);
    font-size: clamp(4rem, 8.7vw, 9.7rem);
    font-weight: 520;
    letter-spacing: -0.075em;
    line-height: 0.82;
    /* miękki granatowy cień oddziela tekst od baniek przelatujących pod spodem */
    text-shadow: 0 0.35rem 1.6rem rgba(7, 16, 64, 0.45);
  }

  .cities-physics__header h2 em {
    color: transparent;
    font-style: normal;
    -webkit-text-stroke: 1px rgba(246, 247, 241, 0.68);
    text-stroke: 1px rgba(246, 247, 241, 0.68);
  }

  .cities-physics__intro {
    display: flex;
    min-height: 9rem;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.26);
    padding-top: 1.25rem;
  }

  .cities-physics__intro p {
    max-width: 31rem;
    margin: 0;
    color: rgba(246, 247, 241, 0.76);
    font-size: clamp(1rem, 1.28vw, 1.2rem);
    line-height: 1.48;
    text-shadow: 0 0.25rem 1.1rem rgba(7, 16, 64, 0.5);
  }

  .cities-physics__intro span {
    color: rgba(246, 247, 241, 0.48);
    font-family: var(--font-mono, monospace);
    font-size: 0.6rem;
    letter-spacing: 0.11em;
  }

  /* Spacer trzyma wysokość sekcji pod nagłówkiem, gdy warstwa fizyki
     jest absolute (full-bleed). W trybie flow (SSR / reduced) znika. */
  .cities-physics__space {
    display: none;
    pointer-events: none;
  }

  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__space {
    display: block;
    height: clamp(43rem, 63vw, 53rem);
  }

  /* Instrukcja: dyskretny mono-label w lewym dolnym rogu sekcji, bez ramki */
  .cities-physics__instruction {
    position: absolute;
    z-index: 3;
    bottom: 1.1rem;
    left: 1.25rem;
    max-width: 24rem;
    margin: 0;
    color: rgba(246, 247, 241, 0.55);
    font-family: var(--font-mono, monospace);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    line-height: 1.5;
    pointer-events: none;
    text-transform: uppercase;
  }

  /* World bazowo (SSR / brak JS / reduced): statyczna chmura chipów w flow */
  .cities-physics__world {
    position: relative;
    display: flex;
    align-content: center;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    width: min(calc(100% - 40px), 1540px);
    margin: 0 auto;
    padding: 2rem 1.25rem 3.5rem;
    list-style: none;
    touch-action: pan-y;
  }

  /* Bańka: bazowo (SSR / brak JS / reduced-motion) czytelny pigułkowy chip */
  .cities-physics__bubble {
    display: inline-flex;
    min-height: 2rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    background: rgba(255, 255, 255, 0.07);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
    color: var(--cities-white);
    font-family: var(--font-mono, monospace);
    font-size: clamp(0.55rem, 0.72vw, 0.7rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    user-select: none;
    -webkit-user-select: none;
  }

  .cities-physics__bubble span { display: block; }

  .cities-physics__bubble[data-accent='true'] {
    border-color: var(--cities-lime);
    background: var(--cities-lime);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
    color: #08113f;
  }

  /* Bańka: tryb fizyki — okrągła, rozmiar ustala JS inline.
     Premium glass: płaska tafla kobaltu odrobinę jaśniejsza od tła,
     cienki border, JEDEN delikatny inset u góry. Zero błysków. */
  /* Tryb fizyki: world = pełna warstwa sekcji (full-bleed, bez akwarium).
     Banieczki spadają z samej góry sekcji i krążą po całej jej wysokości,
     przelatując POD tekstem nagłówka. Clipping robi overflow sekcji. */
  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__world {
    position: absolute;
    z-index: 1;
    inset: 0;
    display: block;
    width: auto;
    margin: 0;
    padding: 0;
  }

  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__bubble {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    min-height: 0;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
    cursor: grab;
    touch-action: none;
    transform: translate3d(0, 0, 0);
    transform-origin: center;
    will-change: transform;
  }

  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__bubble span {
    max-width: 90%;
    line-height: 1.05;
    letter-spacing: 0.01em;
    /* Pełna nazwa w bańce: łamanie tylko po spacji/myślniku, NIGDY w środku słowa */
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
    -webkit-hyphens: none;
    hyphens: none;
  }

  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__bubble[data-accent='true'] {
    border-color: var(--cities-lime);
    background: var(--cities-lime);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.3);
    color: #08113f;
  }

  .cities-physics[data-physics-ready='true'][data-reduced='false'] .cities-physics__bubble.is-dragged {
    z-index: 3;
    border-color: rgba(255, 255, 255, 0.6);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 1.1rem 2.8rem rgba(3, 8, 40, 0.35);
    cursor: grabbing;
  }

  .cities-physics[data-reduced='true'] .cities-physics__world {
    padding-block: 3rem 4rem;
  }

  .cities-physics[data-reduced='true'] .cities-physics__instruction {
    display: none;
  }

  .cities-physics[data-reduced='true'] .cities-physics__bubble {
    position: static;
    width: auto !important;
    height: auto !important;
    font-size: clamp(0.55rem, 0.72vw, 0.7rem) !important;
    transform: none !important;
  }

  @media (max-width: 900px) {
    .cities-physics__header {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .cities-physics__eyebrow { grid-column: auto; }
    .cities-physics__intro { min-height: 0; }
    .cities-physics__space { height: 52rem; }
  }

  @media (max-width: 700px) {
    .cities-physics {
      padding-top: 5.5rem;
    }

    .cities-physics__shell {
      width: calc(100% - 1.25rem);
    }

    .cities-physics__header h2 {
      font-size: clamp(3.7rem, 18vw, 6rem);
    }

    .cities-physics__space { height: 46rem; }

    .cities-physics__world {
      width: calc(100% - 1.25rem);
      padding: 1.5rem 0.55rem 3.2rem;
    }

    .cities-physics__instruction {
      bottom: 0.9rem;
      left: 0.65rem;
      max-width: calc(100% - 1.3rem);
      font-size: 0.48rem;
    }

    .cities-physics__bubble {
      min-height: 1.7rem;
      padding: 0.43rem 0.62rem;
      font-size: 0.48rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cities-physics__world {
      padding-block: 3rem 4rem;
    }

    .cities-physics__instruction {
      display: none;
    }

    .cities-physics__bubble {
      position: static !important;
      width: auto !important;
      height: auto !important;
      cursor: default !important;
      font-size: clamp(0.55rem, 0.72vw, 0.7rem) !important;
      transform: none !important;
      will-change: auto !important;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-cities-physics]').forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.citiesPhysicsBound) return;
    root.dataset.citiesPhysicsBound = 'true';

    const world = root.querySelector('[data-city-world]');
    const tileElements = [...root.querySelectorAll('[data-city-tile]')];
    if (!(world instanceof HTMLElement) || !tileElements.length) return;

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    // --- Parametry symulacji (dwie fazy: DROP -> WATER) ---
    // DROP: banieczki startują NAD planszą i spadają jak bąbelki wrzucone do
    // wody — grawitacja + żywe odbicia od dna i od siebie.
    // WATER: po opadnięciu wieczne pływanie — wyporność (sinus), dryf,
    // nigdy pełny bezruch.
    const FIXED_STEP = 1 / 120;      // stały krok symulacji
    const MAX_FRAME = 1 / 24;
    const MAX_SUBSTEPS = 6;
    const GRAVITY = 560;             // grawitacja opadu (px/s^2) — wolniejszy, miękki opad
    const DROP_DRAG = 0.12;          // opór ośrodka w locie (1/s)
    const DROP_MAX_SPEED = 1500;     // limit prędkości w opadaniu (px/s)
    const DROP_RESTITUTION = 0.8;    // sprężystość bańka-bańka w opadaniu
    const FLOOR_RESTITUTION = 0.68;  // wyraźne, żywe odbicie od dna
    const DROP_MIN_TIME = 1.4;       // minimalny czas fazy opadania (s)
    const DROP_MAX_TIME = 8;         // twardy limit fazy opadania (s)
    const CALM_SPEED = 30;           // średnia prędkość uznana za "opadłe" (px/s)
    const CALM_HOLD = 0.45;          // ile sekund spokoju zanim włączy się woda
    const WANDER_TURN = 2.2;         // dryf kierunku wędrówki (rad/s)
    const WANDER_ACCEL = 13;         // losowa siła wędrówki (px/s^2)
    const BOB_ACCEL = 42;            // pionowa wyporność, sinus (px/s^2) — wyraźne unoszenie
    const BUOY_UP = 24;              // stały bias KU GÓRZE (px/s^2) — żywy obieg góra-dół
    const SWAY_ACCEL = 9;            // poziome kołysanie, sinus (px/s^2)
    const WATER_DAMP = 1.1;          // tłumienie w wodzie (1/s) — płynnie, nie nerwowo
    const WATER_RESTITUTION = 0.9;   // sprężystość bańka-bańka w wodzie
    const WATER_WALL_RESTITUTION = 0.85; // odbicie od krawędzi w wodzie (sufit domknięty)
    const MIN_SPEED = 4;             // dolny próg prędkości — nic nigdy nie zamiera (px/s)
    const WATER_MAX_SPEED = 170;     // górny limit w wodzie (pozwala na rzut po puszczeniu)
    const CORRECTION = 0.85;         // korekcja pozycji przy nakładaniu
    const TRANSFORM_DPR = Math.min(1.5, Math.max(1, window.devicePixelRatio || 1));

    let seed = 0x5fa12026;
    let width = 0;
    let height = 0;
    let maxRadius = 1;
    let cellSize = 96;
    let refRadius = 24;
    let totalPop = 0;
    let initialized = false;
    let reducedMotion = motionQuery.matches;
    let inView = false;
    let running = false;
    let rafId = 0;
    let resizeFrame = 0;
    let lastTime = 0;
    let accumulator = 0;
    let observer = null;
    let resizeObserver = null;
    let phase = 'drop';   // 'drop' (opadanie) -> 'water' (wieczne pływanie)
    let phaseTime = 0;
    let calmTime = 0;
    let simTime = 0;

    const random = () => {
      seed = (Math.imul(seed, 1664525) + 1013904223) >>> 0;
      return seed / 4294967296;
    };

    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

    const bodies = tileElements.map((element, index) => {
      const label = (element.dataset.city || element.textContent || '').trim();
      const longest = label
        .split(/[\s-]+/)
        .reduce((acc, word) => Math.max(acc, word.length), 1);
      const pop = Number(element.dataset.pop) || 45;
      totalPop += pop;
      return {
        element,
        index,
        pop,
        longest,
        r: 24,
        mass: 1,
        speedScale: 1,
        cx: 0,
        cy: 0,
        vx: 0,
        vy: 0,
        heading: 0,
        bobFreq: 0.7,
        bobPhase: 0,
        swayFreq: 0.45,
        swayPhase: 0,
        dragged: false,
        pointerId: null,
        dragOffsetX: 0,
        dragOffsetY: 0,
        dragWorldLeft: 0,
        dragWorldTop: 0,
        targetX: 0,
        targetY: 0,
        lastTransform: '',
      };
    });

    const renderBody = (body) => {
      const x = Number.isFinite(body.cx) ? body.cx - body.r : 0;
      const y = Number.isFinite(body.cy) ? body.cy - body.r : 0;
      const renderX = Math.round(x * TRANSFORM_DPR) / TRANSFORM_DPR;
      const renderY = Math.round(y * TRANSFORM_DPR) / TRANSFORM_DPR;
      const transform = `translate3d(${renderX}px, ${renderY}px, 0)`;
      if (transform === body.lastTransform) return;
      body.lastTransform = transform;
      body.element.style.transform = transform;
    };

    const clearInline = (body) => {
      body.lastTransform = '';
      body.element.style.removeProperty('transform');
      body.element.style.removeProperty('width');
      body.element.style.removeProperty('height');
      body.element.style.removeProperty('font-size');
    };

    // Rozmiar bańki: pole ∝ populacja (r ~ sqrt(pop)), skala dopasowana do planszy.
    const layout = () => {
      resizeFrame = 0;
      if (!root.isConnected || reducedMotion) return;
      const previousWidth = width;
      const previousHeight = height;
      const bounds = world.getBoundingClientRect();
      width = Math.max(1, bounds.width);
      height = Math.max(1, bounds.height);

      const area = width * height;
      const isMobile = width < 620;
      // Full-bleed: plansza = cała sekcja (większa niż dawne akwarium),
      // więc niższy współczynnik wypełnienia trzyma przewiewną kompozycję.
      const targetFill = isMobile ? 0.46 : 0.5;
      const scale = (targetFill * area) / Math.max(1, totalPop);
      const minR = clamp(Math.min(width, height) * 0.05, isMobile ? 17 : 22, 46);
      const maxR = clamp(Math.min(width, height) * 0.17, minR + 8, isMobile ? 72 : 122);

      // Dopasowanie tekstu: najdłuższe SŁOWO nazwy musi zmieścić się w cięciwie
      // koła na jednej linii (font mono ~0.62em/znak, ~82% średnicy na tekst).
      const CHAR_W = 0.62;
      const TEXT_FRAC = 0.82;
      const FLOOR_FONT = isMobile ? 6.5 : 7.5; // czytelny dolny próg fontu

      maxRadius = 1;
      bodies.forEach((body) => {
        const raw = Math.sqrt((scale * body.pop) / Math.PI);
        let r = clamp(raw, minR, maxR);
        // Priorytet czytelności: podnieś promień, jeśli najdłuższe słowo nie
        // zmieściłoby się przy dolnym progu fontu.
        const minRForName = (body.longest * CHAR_W * FLOOR_FONT) / (2 * TEXT_FRAC);
        r = clamp(Math.max(r, minRForName), minR, maxR);
        body.r = r;
        maxRadius = Math.max(maxRadius, r);
        body.mass = Math.max(0.4, body.pop / 300);
        const diameter = Math.round(r * 2);
        body.element.style.width = `${diameter}px`;
        body.element.style.height = `${diameter}px`;
        // Font liczony z cięciwy: najdłuższe słowo mieści się na jednej linii.
        // Gdy maxR ograniczy promień, font może zejść nieco niżej, byle nazwa
        // była cała widoczna (nigdy nie łamiemy w środku słowa).
        const fitFont = (2 * r * TEXT_FRAC) / (body.longest * CHAR_W);
        const fontPx = clamp(fitFont, 5.5, r * 0.5);
        body.element.style.fontSize = `${fontPx.toFixed(2)}px`;
      });

      refRadius = (minR + maxR) / 2;
      cellSize = Math.max(64, maxRadius * 2);
      bodies.forEach((body) => {
        body.speedScale = clamp(refRadius / body.r, 0.6, 1.65);
      });

      if (!initialized) {
        // Spawn U GÓRY: banieczki startują nad planszą (niewidoczne, overflow
        // hidden) i po wejściu sekcji w viewport spadają w dół jak do wody.
        seed = 0x5fa12026;
        phase = 'drop';
        phaseTime = 0;
        calmTime = 0;
        simTime = 0;
        bodies.forEach((body) => {
          const spanX = Math.max(0, width - 2 * body.r);
          body.cx = body.r + random() * spanX;
          body.cy = -body.r - random() * height * 1.05;
          body.vx = (random() - 0.5) * 30;
          body.vy = random() * 40;
          body.heading = random() * Math.PI * 2;
          body.bobFreq = 0.5 + random() * 0.4;
          body.bobPhase = random() * Math.PI * 2;
          body.swayFreq = 0.3 + random() * 0.3;
          body.swayPhase = random() * Math.PI * 2;
        });
        // Rozepchnij nakładki w strefie spawnu (tylko boki — góra otwarta)
        for (let pass = 0; pass < 6; pass += 1) {
          solveCollisions();
          bodies.forEach((body) => {
            body.cx = clamp(body.cx, body.r, Math.max(body.r, width - body.r));
          });
        }
        initialized = true;
      } else if (previousWidth > 1 && previousHeight > 1) {
        const rx = width / previousWidth;
        const ry = height / previousHeight;
        bodies.forEach((body) => {
          body.cx = clamp(body.cx * rx, body.r, Math.max(body.r, width - body.r));
          // W fazie opadania góra jest otwarta — nie przycinaj ujemnego cy.
          const scaledY = body.cy * ry;
          body.cy = phase === 'drop'
            ? Math.min(scaledY, Math.max(body.r, height - body.r))
            : clamp(scaledY, body.r, Math.max(body.r, height - body.r));
        });
      }

      bodies.forEach(renderBody);
      root.dataset.physicsReady = 'true';
    };

    const scheduleResize = () => {
      if (resizeFrame || reducedMotion) return;
      resizeFrame = requestAnimationFrame(layout);
    };

    const constrainWalls = (body) => {
      const wallE = phase === 'drop' ? FLOOR_RESTITUTION : WATER_WALL_RESTITUTION;
      const minX = Math.min(body.r, width / 2);
      const maxX = Math.max(width - body.r, width / 2);
      const minY = Math.min(body.r, height / 2);
      const maxY = Math.max(height - body.r, height / 2);
      if (body.cx < minX) {
        body.cx = minX;
        if (body.vx < 0) body.vx *= -wallE;
      } else if (body.cx > maxX) {
        body.cx = maxX;
        if (body.vx > 0) body.vx *= -wallE;
      }
      // Sufit działa dopiero w wodzie — w fazie opadania góra jest otwarta,
      // bo banieczki wpadają spoza planszy.
      if (phase === 'water' && body.cy < minY) {
        body.cy = minY;
        if (body.vy < 0) body.vy *= -wallE;
      } else if (body.cy > maxY) {
        body.cy = maxY;
        if (body.vy > 0) body.vy *= -wallE;
      }
    };

    const integrate = (body, step) => {
      if (body.dragged) {
        const nx = clamp(body.targetX, body.r, Math.max(body.r, width - body.r));
        const ny = clamp(body.targetY, body.r, Math.max(body.r, height - body.r));
        body.vx = clamp((nx - body.cx) / step, -1600, 1600);
        body.vy = clamp((ny - body.cy) / step, -1600, 1600);
        body.cx = nx;
        body.cy = ny;
        return;
      }

      if (phase === 'drop') {
        // OPAD: grawitacja + lekki opór ośrodka, odbicia robi solver
        body.vy += GRAVITY * step;
        const drag = Math.max(0, 1 - DROP_DRAG * step);
        body.vx *= drag;
        body.vy *= drag;
        const dropSpeed = Math.hypot(body.vx, body.vy);
        if (dropSpeed > DROP_MAX_SPEED) {
          const k = DROP_MAX_SPEED / dropSpeed;
          body.vx *= k;
          body.vy *= k;
        }
        body.cx += body.vx * step;
        body.cy += body.vy * step;
        constrainWalls(body);
        return;
      }

      // WODA: wędrówka (małe losowe siły) + wyporność sinusowa —
      // powolne unoszenie i opadanie, ciągły subtelny ruch
      body.heading += (random() - 0.5) * WANDER_TURN * step;
      const wander = WANDER_ACCEL * body.speedScale;
      body.vx += Math.cos(body.heading) * wander * step;
      body.vy += Math.sin(body.heading) * wander * step;
      body.vx += Math.sin(simTime * body.swayFreq + body.swayPhase) * SWAY_ACCEL * step;
      body.vy += Math.sin(simTime * body.bobFreq + body.bobPhase) * BOB_ACCEL * step;
      // bias ku górze: bąbelki dryfują w górę (małe szybciej), odbijają się
      // od domkniętego sufitu, a faza sinusa sprowadza je z powrotem w dół
      body.vy -= BUOY_UP * body.speedScale * step;

      // tłumienie (opór wody)
      const damp = Math.max(0, 1 - WATER_DAMP * step);
      body.vx *= damp;
      body.vy *= damp;

      body.cx += body.vx * step;
      body.cy += body.vy * step;

      // limity prędkości: nic nie zamiera i nic nie wybucha
      const speed = Math.hypot(body.vx, body.vy);
      const minSpeed = MIN_SPEED * body.speedScale;
      if (speed > WATER_MAX_SPEED) {
        const k = WATER_MAX_SPEED / speed;
        body.vx *= k;
        body.vy *= k;
      } else if (speed < minSpeed) {
        if (speed > 0.0001) {
          const k = minSpeed / speed;
          body.vx *= k;
          body.vy *= k;
        } else {
          body.heading = random() * Math.PI * 2;
          body.vx = Math.cos(body.heading) * minSpeed;
          body.vy = Math.sin(body.heading) * minSpeed;
        }
      }

      constrainWalls(body);
    };

    // Kolizja okrąg-okrąg (rozpychanie + sprężyste odbicie)
    const resolvePair = (a, b) => {
      let dx = b.cx - a.cx;
      let dy = b.cy - a.cy;
      const minDist = a.r + b.r;
      let dist2 = dx * dx + dy * dy;
      if (dist2 >= minDist * minDist) return;

      let dist = Math.sqrt(dist2);
      if (dist < 0.0001) {
        // idealne pokrycie — rozepchnij losowym kierunkiem
        const angle = random() * Math.PI * 2;
        dx = Math.cos(angle);
        dy = Math.sin(angle);
        dist = 0.0001;
      }
      const nx = dx / dist;
      const ny = dy / dist;
      const overlap = minDist - dist;

      const invA = a.dragged ? 0 : 1 / a.mass;
      const invB = b.dragged ? 0 : 1 / b.mass;
      const invTotal = invA + invB;
      if (invTotal <= 0) return;

      // korekcja pozycji proporcjonalna do odwrotności masy
      const corr = (overlap * CORRECTION) / invTotal;
      a.cx -= nx * corr * invA;
      a.cy -= ny * corr * invA;
      b.cx += nx * corr * invB;
      b.cy += ny * corr * invB;

      // impuls sprężysty wzdłuż normalnej (żywszy w opadaniu)
      const relN = (b.vx - a.vx) * nx + (b.vy - a.vy) * ny;
      if (relN > 0) return; // już się rozdzielają
      const restitution = phase === 'drop' ? DROP_RESTITUTION : WATER_RESTITUTION;
      const j = (-(1 + restitution) * relN) / invTotal;
      a.vx -= j * nx * invA;
      a.vy -= j * ny * invA;
      b.vx += j * nx * invB;
      b.vy += j * ny * invB;
    };

    // Spatial hashing — bbox bańki wpada do pokrywanych komórek
    const solveCollisions = () => {
      const buckets = new Map();
      bodies.forEach((body) => {
        const minColumn = Math.floor((body.cx - body.r) / cellSize);
        const maxColumn = Math.floor((body.cx + body.r) / cellSize);
        const minRow = Math.floor((body.cy - body.r) / cellSize);
        const maxRow = Math.floor((body.cy + body.r) / cellSize);
        for (let column = minColumn; column <= maxColumn; column += 1) {
          for (let row = minRow; row <= maxRow; row += 1) {
            const key = `${column}:${row}`;
            const bucket = buckets.get(key);
            if (bucket) bucket.push(body);
            else buckets.set(key, [body]);
          }
        }
      });

      const checked = new Set();
      buckets.forEach((bucket) => {
        for (let aIndex = 0; aIndex < bucket.length; aIndex += 1) {
          for (let bIndex = aIndex + 1; bIndex < bucket.length; bIndex += 1) {
            const a = bucket[aIndex];
            const b = bucket[bIndex];
            const key = a.index < b.index ? `${a.index}:${b.index}` : `${b.index}:${a.index}`;
            if (checked.has(key)) continue;
            checked.add(key);
            resolvePair(a, b);
          }
        }
      });
    };

    const simulate = (step) => {
      simTime += step;
      phaseTime += step;
      bodies.forEach((body) => integrate(body, step));
      for (let iteration = 0; iteration < 2; iteration += 1) {
        solveCollisions();
        bodies.forEach(constrainWalls);
      }
      // Przejście DROP -> WATER: wszystko opadło i się uspokoiło
      if (phase === 'drop') {
        let sum = 0;
        let count = 0;
        bodies.forEach((body) => {
          if (!body.dragged) {
            sum += Math.hypot(body.vx, body.vy);
            count += 1;
          }
        });
        const avgSpeed = count ? sum / count : 0;
        if (phaseTime > DROP_MIN_TIME && avgSpeed < CALM_SPEED) calmTime += step;
        else calmTime = 0;
        if (calmTime >= CALM_HOLD || phaseTime >= DROP_MAX_TIME) phase = 'water';
      }
    };

    const frame = (time) => {
      if (!running) return;
      if (!root.isConnected) {
        cleanup();
        return;
      }
      if (!lastTime) lastTime = time;
      accumulator += Math.min(MAX_FRAME, (time - lastTime) / 1000);
      lastTime = time;
      let substeps = 0;
      while (accumulator >= FIXED_STEP && substeps < MAX_SUBSTEPS) {
        simulate(FIXED_STEP);
        accumulator -= FIXED_STEP;
        substeps += 1;
      }
      if (substeps === MAX_SUBSTEPS) accumulator = 0;
      bodies.forEach(renderBody);
      rafId = requestAnimationFrame(frame);
    };

    const start = () => {
      if (running || reducedMotion || !inView || document.hidden) return;
      running = true;
      lastTime = 0;
      accumulator = 0;
      rafId = requestAnimationFrame(frame);
    };

    const stop = () => {
      running = false;
      cancelAnimationFrame(rafId);
      rafId = 0;
      lastTime = 0;
      accumulator = 0;
    };

    const finishDrag = (body, event) => {
      if (!body.dragged || (event && body.pointerId !== event.pointerId)) return;
      body.dragged = false;
      body.pointerId = null;
      body.element.classList.remove('is-dragged');
      if (event && body.element.hasPointerCapture?.(event.pointerId)) {
        try { body.element.releasePointerCapture(event.pointerId); } catch {}
      }
    };

    bodies.forEach((body) => {
      body.element.addEventListener('pointerdown', (event) => {
        if (reducedMotion || event.button !== 0) return;
        event.preventDefault();
        const bounds = world.getBoundingClientRect();
        body.dragged = true;
        body.pointerId = event.pointerId;
        body.dragWorldLeft = bounds.left;
        body.dragWorldTop = bounds.top;
        body.dragOffsetX = event.clientX - bounds.left - body.cx;
        body.dragOffsetY = event.clientY - bounds.top - body.cy;
        body.targetX = body.cx;
        body.targetY = body.cy;
        body.element.classList.add('is-dragged');
        try { body.element.setPointerCapture(event.pointerId); } catch {}
        start();
      });

      body.element.addEventListener('pointermove', (event) => {
        if (!body.dragged || body.pointerId !== event.pointerId) return;
        body.targetX = event.clientX - body.dragWorldLeft - body.dragOffsetX;
        body.targetY = event.clientY - body.dragWorldTop - body.dragOffsetY;
      });

      body.element.addEventListener('pointerup', (event) => finishDrag(body, event));
      body.element.addEventListener('pointercancel', (event) => finishDrag(body, event));
      body.element.addEventListener('lostpointercapture', (event) => finishDrag(body, event));
    });

    const applyMotionPreference = () => {
      reducedMotion = motionQuery.matches;
      root.dataset.reduced = String(reducedMotion);
      if (reducedMotion) {
        stop();
        initialized = false;
        root.dataset.physicsReady = 'false';
        bodies.forEach((body) => {
          finishDrag(body);
          clearInline(body);
        });
      } else {
        scheduleResize();
        start();
      }
    };

    const handleVisibility = () => {
      if (document.hidden) stop();
      else start();
    };

    const cleanup = () => {
      stop();
      cancelAnimationFrame(resizeFrame);
      observer?.disconnect();
      resizeObserver?.disconnect();
      window.removeEventListener('resize', scheduleResize);
      document.removeEventListener('visibilitychange', handleVisibility);
      document.removeEventListener('astro:before-swap', cleanup);
      motionQuery.removeEventListener?.('change', applyMotionPreference);
    };

    if ('ResizeObserver' in window) {
      resizeObserver = new ResizeObserver(scheduleResize);
      resizeObserver.observe(world);
    } else {
      window.addEventListener('resize', scheduleResize, { passive: true });
    }

    if ('IntersectionObserver' in window) {
      observer = new IntersectionObserver((entries) => {
        const entry = entries[0];
        inView = Boolean(entry?.isIntersecting && entry.intersectionRatio >= 0.12);
        if (inView) start();
        else stop();
      }, { rootMargin: '0px 0px -12% 0px', threshold: [0, 0.12] });
      observer.observe(world);
    } else {
      inView = true;
    }

    document.addEventListener('visibilitychange', handleVisibility);
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    motionQuery.addEventListener?.('change', applyMotionPreference);
    root.dataset.reduced = String(reducedMotion);
    if (!reducedMotion) scheduleResize();
    if (inView) start();
  });
</script>
