---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  titleAccent?: string;
  intro?: string;
  cities?: string[];
}

// Realne, przybliżone liczby mieszkańców (GUS, w tysiącach).
// Powierzchnia bańki jest proporcjonalna do populacji (promień ~ sqrt(populacja)).
const population: Record<string, number> = {
  'Warszawa': 1860, 'Kraków': 800, 'Łódź': 660, 'Wrocław': 674, 'Poznań': 540,
  'Gdańsk': 486, 'Szczecin': 391, 'Bydgoszcz': 330, 'Lublin': 331, 'Białystok': 295,
  'Katowice': 285, 'Gdynia': 240, 'Częstochowa': 214, 'Radom': 200, 'Sosnowiec': 190,
  'Toruń': 196, 'Kielce': 190, 'Gliwice': 174, 'Zabrze': 168, 'Bytom': 156,
  'Olsztyn': 170, 'Bielsko-Biała': 168, 'Rzeszów': 197, 'Ruda Śląska': 132, 'Rybnik': 132,
  'Tychy': 126, 'Dąbrowa Górnicza': 114, 'Płock': 116, 'Elbląg': 117, 'Opole': 127,
  'Gorzów Wielkopolski': 122, 'Wałbrzych': 103, 'Włocławek': 106, 'Zielona Góra': 141,
  'Tarnów': 105, 'Chorzów': 105, 'Koszalin': 105, 'Kalisz': 96, 'Legnica': 97,
  'Grudziądz': 92, 'Słupsk': 88, 'Jaworzno': 88, 'Jastrzębie-Zdrój': 84, 'Nowy Sącz': 83,
  'Jelenia Góra': 76, 'Konin': 71, 'Siedlce': 77, 'Mysłowice': 74, 'Piła': 71,
  'Ostrów Wielkopolski': 72, 'Lubin': 71, 'Suwałki': 69, 'Stargard': 66, 'Gniezno': 67,
  'Piotrków Trybunalski': 70, 'Pabianice': 62, 'Inowrocław': 71, 'Ostrowiec Świętokrzyski': 62,
  'Siemianowice Śląskie': 63, 'Głogów': 66, 'Zamość': 62, 'Leszno': 62, 'Chełm': 60,
  'Łomża': 62, 'Żory': 61, 'Tarnowskie Góry': 61, 'Tomaszów Mazowiecki': 60, 'Ełk': 62,
  'Mielec': 60, 'Przemyśl': 58, 'Stalowa Wola': 58, 'Tczew': 59, 'Kędzierzyn-Koźle': 58,
  'Bełchatów': 56, 'Świdnica': 55, 'Będzin': 55, 'Zgierz': 55, 'Piekary Śląskie': 54,
  'Rumia': 50, 'Legionowo': 54, 'Piaseczno': 48, 'Biała Podlaska': 57,
