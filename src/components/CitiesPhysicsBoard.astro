const DEFAULT_POP = 45;
const ACCENT_THRESHOLD = 480; // limonka dla największych miast (>= ~480 tys.)
const populationOf = (name: string) => population[name] ?? DEFAULT_POP;

const defaultCities = [
  'Warszawa',
  'Kraków',
  'Wrocław',
  'Łódź',
  'Poznań',
  'Gdańsk',
  'Szczecin',
  'Lublin',
  'Bydgoszcz',
  'Białystok',
  'Katowice',
  'Gdynia',
  'Częstochowa',
  'Rzeszów',
  'Toruń',
  'Radom',
  'Sosnowiec',
  'Kielce',
  'Gliwice',
  'Olsztyn',
  'Bielsko-Biała',
  'Zabrze',
  'Bytom',
  'Zielona Góra',
  'Rybnik',
  'Ruda Śląska',
  'Opole',
  'Tychy',
  'Gorzów Wielkopolski',
  'Dąbrowa Górnicza',
  'Elbląg',
  'Płock',
  'Koszalin',
  'Tarnów',
  'Chorzów',
  'Włocławek',
  'Wałbrzych',
  'Kalisz',
  'Legnica',
  'Grudziądz',
  'Jaworzno',
  'Słupsk',
  'Jastrzębie-Zdrój',
  'Nowy Sącz',
  'Siedlce',
  'Jelenia Góra',
  'Mysłowice',
  'Piła',
  'Ostrów Wielkopolski',
  'Suwałki',
  'Lubin',
  'Pruszków',
  'Inowrocław',
  'Stargard',
  'Piotrków Trybunalski',
  'Konin',
  'Siemianowice Śląskie',
  'Gniezno',
  'Żory',
  'Tarnowskie Góry',
  'Głogów',
  'Ostrowiec Świętokrzyski',
  'Pabianice',
  'Łomża',
  'Ełk',
  'Leszno',
  'Zamość',
  'Tomaszów Mazowiecki',
