---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/services.js';
import '../../styles/subpage-motion.css';
import valueArchitectureImage from '../../assets/generated/v4/service-value-diagnostic-atlas.png';
import chatbotKnowledgeImage from '../../assets/generated/v4/service-chatbot-knowledge-dialogue.png';
import seoAiCitationsImage from '../../assets/generated/v4/service-geo-citation-ecosystem.png';
import voicebotRobotImage from '../../assets/generated/v4/service-voice-agent-resonance.png';
import aiAgentControlImage from '../../assets/generated/v4/service-agent-human-control.png';
import processAutomationImage from '../../assets/generated/v4/service-workflow-business-artifacts.png';
import aiCareObservatoryImage from '../../assets/generated/v4/service-care-command-observatory.png';

export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug }, props: { service } }));
}

const { service } = Astro.props;
const serviceVisuals = {
  core: {
    src: valueArchitectureImage,
    alt: 'Architektoniczna mapa procesu z jedną wybraną ścieżką wartości wdrożenia AI',
  },
  chat: {
    src: chatbotKnowledgeImage,
    alt: 'Dwie formy rozmowy połączone z uporządkowaną bazą wiedzy firmy',
  },
  search: {
    src: seoAiCitationsImage,
    alt: 'Strona internetowa połączona ze źródłami i cytowaną odpowiedzią systemu AI',
  },
  voice: {
    src: voicebotRobotImage,
    alt: 'Profesjonalny robot AI prowadzący naturalną rozmowę przez mikrofon',
  },
  agent: {
    src: aiAgentControlImage,
    alt: 'Agent AI łączący firmowe narzędzia przez bramkę kontroli człowieka',
  },
  automation: {
    src: processAutomationImage,
    alt: 'Dokumenty przechodzące przez uporządkowane etapy automatycznego procesu',
  },
  care: {
    src: aiCareObservatoryImage,
    alt: 'Operator monitorujący siedem systemów AI i wykryty wyjątek',
  },
};
const heroVisual = serviceVisuals[service.visual] ?? serviceVisuals.core;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  description: service.short,
  provider: { '@type': 'Organization', name: 'SimpleFast.ai', url: 'https://www.simplefast.ai' },
  areaServed: 'PL',
  url: `https://www.simplefast.ai/uslugi/${service.slug}/`,
};
---
<BaseLayout title={`${service.title} dla firm — SimpleFast.ai`} description={service.short} schema={schema}>
  <main id="main" class="subpage-main">
    <section class="subhero service-hero" data-subpage-hero>
      <p class="mono-label">/ Usługa {service.index}</p>
      <div class="service-hero-copy">
        <h1>{service.title}</h1>
        <p>{service.short}</p>
      </div>
      <div class="service-hero-visual" data-image-curtain>
        <Image src={heroVisual.src} alt={heroVisual.alt} widths={[720, 1080, 1500]} sizes="(max-width: 760px) 100vw, 53vw" format="webp" quality={82} loading="eager" />
      </div>
      <div class="service-meta"><span>SimpleFast.ai / {service.index}</span><span>{service.kicker}</span><span>Dane w UE / RODO</span></div>
    </section>

    <section class="service-outcome" data-motion-section>
      <div class="service-outcome-grid section-shell">
        <p class="mono-label">/ Rezultat</p>
        <blockquote>{service.outcome}</blockquote>
        <div class="service-keywords">{service.keywords.map((keyword) => <span>{keyword}</span>)}</div>
      </div>
    </section>

    <section class="content-section" data-motion-section>
      <div class="content-grid section-shell">
        <p class="mono-label">/ Co wdrażamy</p>
        <h2 data-reveal>Technologia dopasowana do procesu.</h2>
        <p class="lead">Zakres ustalamy po krótkiej diagnozie. Każdy projekt ma jasno opisane zadanie, granice działania, sposób kontroli i miarę efektu.</p>
        <div class="feature-grid" data-motion-group>
          {service.useCases.map(([title, description], index) => (
            <article class="feature-card" data-motion-row>
              <span>0{index + 1}</span>
              <h3>{title}</h3>
              <p>{description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section light-section" data-motion-section>
      <div class="content-grid section-shell">
        <p class="mono-label">/ Proces</p>
        <h2 data-reveal>Od diagnozy do działania w czterech krokach.</h2>
        <div class="case-list" data-motion-group>
          <article class="case-row" data-motion-row data-motion-index="01" data-motion-preview="Diagnoza / Wartość"><h3>Diagnoza</h3><p>Mapujemy obecny proces, koszt ręcznej pracy i miejsca, w których sprawa się zatrzymuje.</p><div><strong>01</strong><small>Wartość</small></div></article>
          <article class="case-row" data-motion-row data-motion-index="02" data-motion-preview="Projekt / Architektura"><h3>Projekt</h3><p>Definiujemy przepływ, wiedzę, integracje, wyjątki i zakres odpowiedzialności systemu.</p><div><strong>02</strong><small>Architektura</small></div></article>
          <article class="case-row" data-motion-row data-motion-index="03" data-motion-preview="Wdrożenie / Praktyka"><h3>Wdrożenie</h3><p>Uruchamiamy małą, działającą wersję i testujemy ją na realnych przypadkach.</p><div><strong>03</strong><small>Praktyka</small></div></article>
          <article class="case-row" data-motion-row data-motion-index="04" data-motion-preview="Rozwój / Skala"><h3>Rozwój</h3><p>Monitorujemy jakość, poprawiamy i dodajemy kolejne zadania, gdy efekt jest potwierdzony.</p><div><strong>04</strong><small>Skala</small></div></article>
        </div>
      </div>
    </section>

    <section class="content-section" data-motion-section>
      <div class="content-grid section-shell">
        <p class="mono-label">/ FAQ</p>
        <h2>Najważniejsze pytania przed startem.</h2>
        <div class="faq-list">
          <details class="faq-item"><summary>Ile trwa pierwsze wdrożenie?</summary><p>Zaczynamy od jednego, precyzyjnego procesu. Harmonogram zależy od integracji i jakości danych, ale pierwszą działającą wersję projektujemy jako mały krok, nie wielomiesięczną transformację.</p></details>
          <details class="faq-item"><summary>Czy system działa pod kontrolą człowieka?</summary><p>Tak. Ustalamy granice samodzielnego działania, logujemy akcje i wskazujemy momenty, w których decyzja pozostaje po stronie zespołu.</p></details>
          <details class="faq-item"><summary>Co dzieje się po uruchomieniu?</summary><p>Możesz wybrać stałą Opiekę AI. Monitorujemy działanie, aktualizujemy wiedzę i integracje oraz rozwijamy system wraz ze zmianami w firmie.</p></details>
        </div>
      </div>
    </section>

    <section class="care-callout" data-motion-section>
      <div class="care-callout-inner section-shell">
        <p class="mono-label">/ Bezpłatna diagnoza</p>
        <h2>Sprawdźmy, czy <em>to ma sens.</em></h2>
        <div class="care-callout-copy"><p>30 minut wystarczy, żeby wybrać pierwszy proces i uczciwie ocenić potencjalny efekt.</p><a class="text-link" href="/kontakt/">Umów rozmowę <span>↗</span></a></div>
      </div>
    </section>
  </main>
  <script>
    import '../../scripts/subpage-motion.js';
  </script>
</BaseLayout>
