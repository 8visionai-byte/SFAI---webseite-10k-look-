---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/services.js';
import '../../styles/subpage-motion.css';
import valueArchitectureImage from '../../assets/generated/v4/service-value-diagnostic-atlas.png';
import chatbotKnowledgeImage from '../../assets/generated/v4/service-chatbot-knowledge-dialogue.png';
import seoAiCitationsImage from '../../assets/generated/v4/service-geo-citation-ecosystem.png';
import voicebotRobotImage from '../../assets/generated/v4/service-voice-agent-resonance.png';
import aiAgentControlImage from '../../assets/generated/v4/service-agent-human-control.png';
import processAutomationImage from '../../assets/generated/v4/service-workflow-business-artifacts.png';
import aiCareObservatoryImage from '../../assets/generated/v4/service-care-command-observatory.png';

const serviceVisuals = {
  core: {
    src: valueArchitectureImage,
    alt: 'Architektoniczna mapa procesu z jedną wybraną ścieżką wartości wdrożenia AI',
  },
  chat: {
    src: chatbotKnowledgeImage,
    alt: 'Dwie formy rozmowy połączone z uporządkowaną bazą wiedzy firmy',
  },
  search: {
    src: seoAiCitationsImage,
    alt: 'Strona internetowa połączona ze źródłami i cytowaną odpowiedzią systemu AI',
  },
  voice: {
    src: voicebotRobotImage,
    alt: 'Profesjonalny robot AI prowadzący naturalną rozmowę przez mikrofon',
  },
  agent: {
    src: aiAgentControlImage,
    alt: 'Agent AI łączący firmowe narzędzia przez bramkę kontroli człowieka',
  },
  automation: {
    src: processAutomationImage,
    alt: 'Dokumenty przechodzące przez uporządkowane etapy automatycznego procesu',
  },
  care: {
    src: aiCareObservatoryImage,
    alt: 'Operator monitorujący siedem systemów AI i wykryty wyjątek',
  },
};

const serviceCards = services.map((service) => ({
  ...service,
  visualAsset: serviceVisuals[service.visual] ?? serviceVisuals.core,
}));
---
<BaseLayout
  title="Usługi AI dla firm — SimpleFast.ai"
  description="Architektura wartości AI, agenci, chatboty, voiceboty, automatyzacje, strony pod SEO i AI oraz stała opieka."
>
  <main id="main" class="subpage-main">
    <section class="subhero" data-subpage-hero>
      <p class="mono-label">/ Usługi 01—07</p>
      <span class="subhero-orb" aria-hidden="true"></span>
      <h1>Cały system.<br /><em>Jeden partner.</em></h1>
      <p class="subhero-copy">Od wyboru właściwego procesu, przez projekt i wdrożenie, aż po utrzymanie. Technologia ma się łączyć w całość, a nie tworzyć kolejne silosy.</p>
    </section>

    <section class="content-section" data-motion-section>
      <div class="content-grid section-shell">
        <p class="mono-label">/ Wybierz obszar</p>
        <h2 data-reveal>Zaczynamy od problemu, nie od narzędzia.</h2>
        <p class="lead">Nie musisz wiedzieć, czy potrzebujesz agenta, voicebota czy automatyzacji. Na diagnozie mapujemy proces i rekomendujemy najprostsze rozwiązanie, które dowiezie efekt.</p>
        <div class="listing-grid" data-motion-group>
          {serviceCards.map((service) => (
            <article class="listing-card" data-motion-row>
              <div class="listing-card-visual" data-image-curtain>
                <Image
                  src={service.visualAsset.src}
                  alt={service.visualAsset.alt}
                  widths={[480, 720, 960]}
                  sizes="(max-width: 760px) 100vw, 33vw"
                  format="webp"
                  quality={82}
                  loading="lazy"
                />
              </div>
              <p class="mono-label">{service.index} / {service.kicker}</p>
              <h3>{service.title}</h3>
              <p>{service.short}</p>
              <a class="text-link" href={`/uslugi/${service.slug}/`}>Poznaj usługę <span>↗</span></a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="service-outcome" data-motion-section>
      <div class="service-outcome-grid section-shell">
        <p class="mono-label">/ Nie wiesz, co wybrać?</p>
        <blockquote>Wystarczy, że pokażesz nam pracę, która zabiera czas.</blockquote>
        <div class="service-keywords"><a class="text-link" href="/kontakt/">Umów diagnozę AI <span>↗</span></a></div>
      </div>
    </section>
  </main>
  <script>
    import '../../scripts/subpage-motion.js';
  </script>
</BaseLayout>
