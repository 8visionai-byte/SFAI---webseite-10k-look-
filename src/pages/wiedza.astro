---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import aiAgentControl from '../assets/generated/v3/ai-agent-control.png';
import processAutomation from '../assets/generated/v3/process-automation.png';
import seoAiCitations from '../assets/generated/v3/seo-ai-citations.png';

const articles = [
  {
    category: 'Agenci AI',
    title: 'Agent AI czy chatbot — różnica, którą widać w procesie',
    description: 'Agent nie kończy na odpowiedzi. Sprawdza, zapisuje i wykonuje kolejny krok.',
    image: aiAgentControl,
    alt: 'Agent AI przetwarzający różne dane w kontrolowane działania biznesowe',
  },
  {
    category: 'Automatyzacja',
    title: 'Jak wybrać pierwszy proces do automatyzacji?',
    description: 'Pięć sygnałów, że zadanie jest dobrym kandydatem i trzy, że jeszcze nie.',
    image: processAutomation,
    alt: 'Automatyczny przepływ danych przechodzący przez kolejne etapy procesu',
  },
  {
    category: 'SEO + GEO',
    title: 'Jak przygotować stronę do cytowania przez systemy AI',
    description: 'Architektura treści, dane strukturalne i wiarygodność marki bez skrótów.',
    image: seoAiCitations,
    alt: 'Treści stron internetowych przetwarzane w odpowiedź cytowaną przez system AI',
  },
];
---
<BaseLayout title="Wiedza o AI dla firm — SimpleFast.ai" description="Praktyczne materiały o agentach AI, automatyzacji, voicebotach, chatbotach, SEO/GEO i bezpieczeństwie.">
  <main id="main" class="subpage-main">
    <section class="subhero"><p class="mono-label">/ Baza wiedzy</p><span class="subhero-orb" aria-hidden="true"></span><h1>AI bez hype’u.<br /><em>Z kontekstem.</em></h1><p class="subhero-copy">Materiały dla osób, które chcą podejmować lepsze decyzje o AI: co wdrażać, jak mierzyć, gdzie uważać i kiedy odpuścić.</p></section>
    <section class="content-section">
      <div class="content-grid section-shell">
        <p class="mono-label">/ Tematy</p><h2 data-reveal>O technologii językiem wyniku.</h2>
        <div class="listing-grid">
          {articles.map(({ category, title, description, image, alt }, index) => (
            <article class="listing-card" data-insight-row={index + 1} data-reveal>
              <div class="listing-card-copy">
                <p class="mono-label">0{index + 1} / {category}</p>
                <h3>{title}</h3>
                <p>{description}</p>
                <a class="text-link" href="/kontakt/">Zapytaj o ten temat <span>↗</span></a>
              </div>
              <div class="insight-preview" data-insight-preview={index + 1}>
                <Image
                  src={image}
                  alt={alt}
                  widths={[360, 540, 720]}
                  sizes="(max-width: 760px) 78vw, 28rem"
                  loading="lazy"
                />
                <span class="insight-preview-cta" aria-hidden="true">Czytaj<br />post</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
