---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowCore from '../components/FlowCore.astro';
import EditorialJourney from '../components/EditorialJourney.astro';
import { services } from '../data/services.js';
import valueArchitectureImage from '../assets/generated/v3/value-architecture.png';
import chatbotKnowledgeImage from '../assets/generated/v3/chatbot-knowledge.png';
import voicebotRobotImage from '../assets/generated/v3/voicebot-robot.png';
import careObservatoryImage from '../assets/generated/v3/ai-care-observatory.png';
import seoAiCitationsImage from '../assets/generated/v3/seo-ai-citations.png';
import aiAgentControlImage from '../assets/generated/v3/ai-agent-control.png';
import processAutomationImage from '../assets/generated/v3/process-automation.png';
import humanAiTouchImage from '../assets/generated/v3/human-ai-touch.png';

const marquee = ['Agenci AI', 'Voiceboty', 'Chatboty', 'Automatyzacje', 'SEO + GEO', 'Strony WWW', 'Opieka AI', 'Dane w UE'];
const serviceVisuals = {
  core: { src: valueArchitectureImage, alt: 'Warstwowa mapa strategii i priorytetów wdrożenia AI' },
  chat: { src: chatbotKnowledgeImage, alt: 'Modułowy chatbot łączący pytania klientów z wiedzą firmy' },
  search: { src: seoAiCitationsImage, alt: 'Treści strony prowadzące do odpowiedzi cytowanej przez system AI' },
  voice: { src: voicebotRobotImage, alt: 'Profesjonalny robot AI prowadzący naturalną rozmowę głosową' },
  agent: { src: aiAgentControlImage, alt: 'Agent AI prowadzący zadanie od sygnału do kontrolowanego działania' },
  automation: { src: processAutomationImage, alt: 'Silnik automatyzacji przesyłający dane przez kolejne etapy procesu' },
  care: { src: careObservatoryImage, alt: 'Centrum monitorowania agentów AI z wykrytym wyjątkiem systemowym' },
};
const cinematicFrames = [
  { src: aiAgentControlImage, alt: 'Agent AI porządkujący sygnały i działania', label: 'Sygnał / decyzja', side: 'right' },
  { src: voicebotRobotImage, alt: 'Profesjonalny voicebot prowadzący naturalną rozmowę', label: 'Głos / intencja', side: 'left' },
  { src: seoAiCitationsImage, alt: 'Architektura treści widoczna dla systemów AI', label: 'Wiedza / widoczność', side: 'right' },
  { src: careObservatoryImage, alt: 'Stały monitoring systemów AI', label: 'Kontrola / rozwój', side: 'left' },
];
const sequenceFrames = [
  { src: valueArchitectureImage, label: '01 / Kierunek' },
  { src: chatbotKnowledgeImage, label: '02 / Rozmowa' },
  { src: voicebotRobotImage, label: '03 / Intencja' },
  { src: seoAiCitationsImage, label: '04 / Wiedza' },
  { src: aiAgentControlImage, label: '05 / Decyzja' },
  { src: processAutomationImage, label: '06 / Działanie' },
  { src: careObservatoryImage, label: '07 / Kontrola' },
  { src: humanAiTouchImage, label: '08 / Współpraca' },
];
const insightArticles = [
  { meta: 'Agenci AI / 08 min', title: 'Agent AI czy automatyzacja — od czego zacząć?', text: 'Prosty sposób na wybór pierwszego procesu bez przepalania budżetu.', image: aiAgentControlImage, alt: 'Modułowa architektura agenta AI z bramką kontroli' },
  { meta: 'SEO + GEO / 11 min', title: 'Jak być widocznym w odpowiedziach ChatGPT?', text: 'Co na stronie pomaga systemom AI właściwie zrozumieć markę.', image: seoAiCitationsImage, alt: 'Wizualizacja treści prowadzących do cytowanej odpowiedzi AI' },
  { meta: 'Operacje / 06 min', title: '7 zadań, które agent może przejąć w tym kwartale.', text: 'Praktyczna lista dla sprzedaży, obsługi i back office.', image: processAutomationImage, alt: 'Silnik automatyzacji z kontrolowanym przepływem danych' },
];
const serviceLoop = [...services, ...services];
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://www.simplefast.ai/#organization',
      name: 'SimpleFast.ai',
      url: 'https://www.simplefast.ai',
      email: 'kontakt@simplefast.ai',
      telephone: '+48696674874',
    },
    {
      '@type': 'ItemList',
      name: 'Usługi SimpleFast.ai',
      itemListElement: services.map((service, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `https://www.simplefast.ai/uslugi/${service.slug}/`,
        name: service.title,
      })),
    },
  ],
};
---
<BaseLayout title="SimpleFast.ai — AI, które dowozi" schema={schema}>
  <main id="main">
    <section class="home-hero" data-hero>
      <div class="hero-sticky">
        <div class="hero-grid-lines"></div>
        <FlowCore />

        <div class="hero-copy">
          <div class="hero-kicker eyebrow"><i></i> Systemy AI dla firm / Polska + UE</div>
          <h1 class="hero-title">
            <span class="line"><span>AI, które</span></span>
            <span class="line"><span><em>dowozi.</em></span></span>
          </h1>
        </div>

        <ul class="hero-side-list" aria-label="Zakres usług">
          <li><span data-scramble>Architektura wartości</span></li>
          <li><span data-scramble>Agenci AI</span></li>
          <li><span data-scramble>Voice + chat</span></li>
          <li><span data-scramble>Automatyzacja</span></li>
          <li><span data-scramble>Web / SEO / GEO</span></li>
        </ul>

        <div class="hero-scenes" aria-hidden="true">
          <div class="hero-scene" data-hero-scene><span>01 / Sygnał</span><b>Słucha</b></div>
          <div class="hero-scene" data-hero-scene><span>02 / Kontekst</span><b>Rozumie</b></div>
          <div class="hero-scene" data-hero-scene><span>03 / Proces</span><b>Działa</b></div>
          <div class="hero-scene" data-hero-scene><span>04 / Wynik</span><b>Dowozi</b></div>
        </div>

        <div class="hero-bottom">
          <p class="hero-intro">Projektujemy agentów, automatyzacje i cyfrowe doświadczenia, które zdejmują z zespołu realną pracę — nie tylko robią wrażenie na demo.</p>
          <div class="hero-actions">
            <a class="button button-primary magnetic" href="/kontakt/"><span>Umów diagnozę AI</span><span>↗</span></a>
            <a class="button magnetic" href="#uslugi"><span>Zobacz usługi</span><span>↓</span></a>
          </div>
          <a class="hero-scroll" href="#manifest">Przewiń</a>
        </div>
      </div>
    </section>

    <div class="marquee-band" aria-label="Zakres kompetencji">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((item) => <span>{item}</span>)}
      </div>
    </div>

    <section class="manifesto" id="manifest">
      <div class="manifesto-grid section-shell">
        <p class="mono-label">/ Nasze podejście</p>
        <h2 data-reveal>Nie wdrażamy AI dla efektu wow. <span>Wdrażamy efekt, który widać w pracy.</span></h2>
        <div class="manifesto-copy" data-reveal>
          <p>Najpierw znajdujemy proces, w którym znika czas lub sprzedaż. Dopiero potem dobieramy model, narzędzia i integracje.</p>
          <p>Budujemy mały, działający system, mierzymy efekt i rozwijamy go wtedy, kiedy biznes jest na to gotowy.</p>
        </div>
      </div>
    </section>

    <section class="human-ai-bridge" data-human-bridge>
      <div class="human-ai-bridge__sticky">
        <div class="human-ai-bridge__media" data-human-bridge-media>
          <Image
            src={humanAiTouchImage}
            alt="Ludzka dłoń i precyzyjna dłoń robota spotykające się na granicy dwóch światów"
            widths={[960, 1440, 1920, 2400]}
            sizes="100vw"
            format="webp"
            quality={88}
          />
        </div>
      </div>
    </section>

    <section class="cinematic-system" data-cinematic aria-label="System AI w ruchu">
      <div class="cinematic-sticky">
        <div class="cinematic-curtain" data-cinematic-curtain></div>
        <div class="cinematic-chapter"><span>[ System / 01—04 ]</span><span>Scroll to orchestrate</span></div>
        <div class="cinematic-frames">
          {cinematicFrames.map((frame, index) => (
            <figure class:list={['cinematic-frame', `cinematic-frame-${index + 1}`, `is-${frame.side}`]} data-cinematic-frame={index}>
              <Image src={frame.src} alt={frame.alt} widths={[540, 820, 1100]} sizes="(max-width: 760px) 82vw, 38vw" format="webp" quality={84} />
              <figcaption>{frame.label}</figcaption>
            </figure>
          ))}
        </div>
        <h2 class="cinematic-title" aria-label="Od pierwszego sygnału do działania pod kontrolą">
          <span>Od pierwszego <em>sygnału</em></span>
          <span>do działania</span>
          <span>pod kontrolą.</span>
        </h2>
        <div class="cinematic-progress" aria-hidden="true"><i data-cinematic-progress></i></div>
      </div>
    </section>

    <EditorialJourney />

    <section class="sequence-lab">
      <div class="sequence-grid section-shell">
        <div class="sequence-copy">
          <p class="mono-label">/ Jedno wdrożenie. Wiele perspektyw.</p>
          <h2 data-reveal>Najedź. Zobacz, jak system dojrzewa.</h2>
          <p>To nie film. Każda klatka pokazuje kolejny etap: od znalezienia wartości, przez rozmowę i decyzję, po kontrolowane działanie.</p>
        </div>
        <div class="image-sequence" data-image-sequence tabindex="0" role="button" aria-pressed="false" aria-label="Uruchom interaktywną sekwencję ośmiu etapów systemu AI">
          <div class="sequence-frames">
            {sequenceFrames.map((frame, index) => (
              <figure class:list={['sequence-frame', index === 0 && 'is-active']} data-sequence-frame={index} data-label={frame.label}>
                <Image src={frame.src} alt="" widths={[720, 1080, 1440]} sizes="(max-width: 760px) 100vw, 58vw" format="webp" quality={82} />
              </figure>
            ))}
          </div>
          <div class="sequence-interface">
            <span data-sequence-label>{sequenceFrames[0].label}</span>
            <span>Hover / hold</span>
            <div class="sequence-ticks">{sequenceFrames.map((_, index) => <i class:list={[index === 0 && 'is-active']}></i>)}</div>
          </div>
          <div class="sequence-cursor" aria-hidden="true"><span>Uruchom<br />sekwencję</span></div>
        </div>
      </div>
    </section>

    <section class="system-story">
      <div class="story-grid">
        <div class="story-media">
          <Image src={aiAgentControlImage} alt="Architektura agenta AI prowadząca zadanie od sygnału do kontrolowanego wyniku" widths={[760, 1100, 1500]} sizes="(max-width: 760px) 100vw, 52vw" format="webp" quality={84} />
          <div class="story-media-copy"><span>Flow architecture</span><span>Scroll / 01—03</span></div>
        </div>
        <div class="story-steps">
          <div class="story-intro">
            <p class="mono-label">/ Od chaosu do wyniku</p>
            <h2>Jeden przepływ. Zero ręcznego pilnowania.</h2>
            <p>Agent łączy telefon, czat, e-mail, dokumenty i systemy firmy w proces, który ma początek, kontrolę i konkretny koniec.</p>
          </div>
          <article class="story-step" data-story-step>
            <span>01</span>
            <div>
              <h3>Słucha sygnału</h3>
              <p>Odbiera telefon, czyta wiadomość, dokument lub zmianę statusu w systemie.</p>
              <strong>Telefon · e-mail · formularz · CRM</strong>
            </div>
          </article>
          <article class="story-step" data-story-step>
            <span>02</span>
            <div>
              <h3>Rozumie kontekst</h3>
              <p>Korzysta z firmowej wiedzy i reguł, sprawdza dane oraz rozpoznaje, co wymaga decyzji człowieka.</p>
              <strong>Wiedza · zasady · bezpieczeństwo</strong>
            </div>
          </article>
          <article class="story-step" data-story-step>
            <span>03</span>
            <div>
              <h3>Wykonuje pracę</h3>
              <p>Umawia termin, aktualizuje CRM, tworzy dokument, przekazuje wyjątek i zapisuje każdą akcję.</p>
              <strong>Akcja · kontrola · wynik</strong>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="services-section" id="uslugi">
      <div class="section-shell">
        <div class="section-heading">
          <p class="mono-label">/ 07 specjalizacji</p>
          <h2 data-reveal>Budujemy cały system AI.</h2>
          <p data-reveal>Od znalezienia wartości, przez wdrożenie, aż po codzienną opiekę i rozwój.</p>
        </div>

        <div class="services-stack">
          {services.map((service, index) => (
            <article class="service-card" data-accent={service.accent} style={`--index:${index}`}>
              <div class="service-card-copy">
                <div class="service-card-head"><span>{service.index}</span><span>{service.kicker}</span></div>
                <h3>{service.title}</h3>
                <p class="service-card-desc">{service.short}</p>
                <div class="service-card-outcome"><span>Rezultat</span><p>{service.outcome}</p></div>
                <a class="service-card-link" href={`/uslugi/${service.slug}/`}><i>↗</i> <span data-scramble>Zobacz usługę</span></a>
              </div>
              <div class="service-card-media">
                <Image src={serviceVisuals[service.visual].src} alt={serviceVisuals[service.visual].alt} widths={[640, 960, 1280]} sizes="(max-width: 760px) 100vw, 50vw" format="webp" quality={84} />
                <div class="service-media-ui" aria-hidden="true"><span>System / {service.index}</span><i></i><span>Live architecture</span></div>
                <span class="media-label">SimpleFast / {service.index}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="proof-section">
      <div class="section-shell">
        <div class="proof-head">
          <p class="mono-label">/ Efekt w procesie</p>
          <h2 data-reveal>Technologia znika. Zostaje lepsza praca.</h2>
        </div>
        <div class="proof-grid">
          <a class="proof-card" href="/uslugi/voiceboty-ai/">
            <div class="proof-card-media"><Image src={voicebotRobotImage} alt="Profesjonalny robot voicebota prowadzący naturalną rozmowę głosową" widths={[760,1100,1500]} sizes="(max-width:760px) 100vw, 54vw" format="webp" quality={84} /></div>
            <div class="proof-card-copy">
              <p class="mono-label">Scenariusz / Obsługa klienta</p>
              <h3>Telefon odebrany. Termin zapisany. Zespół nadal pracuje.</h3>
              <div class="proof-metrics"><div><strong>24/7</strong><span>dostępność</span></div><div><strong>PL</strong><span>naturalna rozmowa</span></div><div><strong>CRM</strong><span>zapis wyniku</span></div></div>
            </div>
          </a>
          <a class="proof-card" href="/uslugi/strony-www-seo-ai/">
            <div class="proof-card-media"><Image src={seoAiCitationsImage} alt="Treści strony i źródła prowadzące do cytowanej odpowiedzi systemu AI" widths={[640,960,1280]} sizes="(max-width:760px) 100vw, 46vw" format="webp" quality={84} /></div>
            <div class="proof-card-copy">
              <p class="mono-label">Scenariusz / Widoczność</p>
              <h3>Jedna strona. Dwa ekosystemy wyszukiwania.</h3>
              <div class="proof-metrics"><div><strong>SEO</strong><span>Google</span></div><div><strong>GEO</strong><span>odpowiedzi AI</span></div><div><strong>UX</strong><span>konwersja</span></div></div>
            </div>
          </a>
          <div class="proof-note"><p>Nie publikujemy zmyślonych wskaźników. W realizacjach pokazujemy tylko efekty, które można przypisać do konkretnego procesu i potwierdzić z klientem.</p></div>
        </div>
      </div>
    </section>

    <section class="process-section">
      <div class="section-shell">
        <div class="process-title">
          <p class="mono-label">/ Jak pracujemy</p>
          <h2 data-reveal>Mały krok. Szybki dowód. Stały rozwój.</h2>
        </div>
        <div class="process-list">
          <article class="process-item" data-process-row><span>01</span><h3><span class="process-title-sr">Diagnoza wartości</span><span aria-hidden="true" data-process-scramble>Diagnoza wartości</span></h3><p>Wybieramy proces, w którym efekt będzie widoczny i mierzalny.</p></article>
          <article class="process-item" data-process-row><span>02</span><h3><span class="process-title-sr">Pierwszy system</span><span aria-hidden="true" data-process-scramble>Pierwszy system</span></h3><p>Budujemy najmniejszą wersję, która naprawdę wykonuje pracę.</p></article>
          <article class="process-item" data-process-row><span>03</span><h3><span class="process-title-sr">Test na żywo</span><span aria-hidden="true" data-process-scramble>Test na żywo</span></h3><p>Sprawdzamy wyjątki, bezpieczeństwo i zachowanie w realnym procesie.</p></article>
          <article class="process-item" data-process-row><span>04</span><h3><span class="process-title-sr">Opieka i skala</span><span aria-hidden="true" data-process-scramble>Opieka i skala</span></h3><p>Monitorujemy wynik, poprawiamy i dodajemy następne zadania.</p></article>
        </div>
      </div>
    </section>

    <section class="services-reel-section">
      <div class="reel-heading section-shell">
        <p class="mono-label">/ Porozmawiajmy o usługach</p>
        <h2 data-reveal>Jeden partner.<br />Cały ekosystem AI.</h2>
        <p>Najedź na wybraną usługę albo przesuń karuzelę na telefonie. Każda ma własną podstronę, zakres i architekturę treści pod dalsze pozycjonowanie.</p>
      </div>
      <div class="services-reel" data-services-reel>
        <div class="services-reel-track">
          {serviceLoop.map((service, loopIndex) => (
            <a class="reel-card" href={`/uslugi/${service.slug}/`} aria-hidden={loopIndex >= services.length ? 'true' : undefined} tabindex={loopIndex >= services.length ? -1 : undefined}>
              <div class="reel-card-media">
                <Image src={serviceVisuals[service.visual].src} alt={loopIndex < services.length ? serviceVisuals[service.visual].alt : ''} widths={[480, 720, 960]} sizes="(max-width: 760px) 76vw, 30vw" format="webp" quality={82} />
              </div>
              <div class="reel-card-copy"><span>{service.index}</span><h3 data-scramble>{service.title}</h3><i>↗</i></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="care-callout">
      <div class="care-callout-visual" aria-hidden="true">
        <Image src={careObservatoryImage} alt="" widths={[720,1080,1440]} sizes="(max-width:760px) 100vw, 58vw" format="webp" quality={84} />
        <span>[ 07 systems / monitored ]</span>
      </div>
      <div class="care-callout-inner section-shell">
        <p class="mono-label">/ Opieka AI</p>
        <h2 data-reveal>Twój dział AI. <em>Bez rekrutacji.</em></h2>
        <div class="care-callout-copy" data-reveal>
          <p>Po wdrożeniu nie zostajesz z panelem, hasłem i instrukcją. Pilnujemy jakości, aktualizujemy wiedzę, rozwijamy integracje i reagujemy na zmiany w firmie.</p>
          <a class="text-link" href="/uslugi/opieka-ai/">Zobacz stałą opiekę <span>↗</span></a>
        </div>
      </div>
    </section>

    <section class="insights-section">
      <div class="section-shell">
        <div class="section-heading">
          <p class="mono-label">/ Wiedza bez hype’u</p>
          <h2 data-reveal>Co działa w AI dla firm.</h2>
          <p>Konkretnie o procesach, kosztach, bezpieczeństwie i widoczności.</p>
        </div>
        <div class="insights-list">
          {insightArticles.map((article, index) => (
            <a class="insight-row" href="/wiedza/" data-insight-row={index + 1}>
              <time>{article.meta}</time>
              <h3>{article.title}</h3>
              <p>{article.text}</p>
              <span class="insight-row-arrow">↗</span>
              <div class="insight-preview" data-insight-preview={index + 1}>
                <Image src={article.image} alt={article.alt} widths={[420, 640, 840]} sizes="(max-width:760px) 100vw, 30rem" format="webp" quality={82} />
                <span class="insight-preview-cta" aria-hidden="true">Czytaj<br />post</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
