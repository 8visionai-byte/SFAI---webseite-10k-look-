            <a class="reel-card" href={`/uslugi/${service.slug}/`} aria-hidden={loopIndex >= services.length ? 'true' : undefined} tabindex={loopIndex >= services.length ? -1 : undefined}>
              <div class="reel-card-media">
                <Image src={serviceVisuals[service.visual].src} alt={loopIndex < services.length ? serviceVisuals[service.visual].alt : ''} widths={[480, 720, 960]} sizes="(max-width: 760px) 76vw, 30vw" format="webp" quality={82} />
              </div>
              <div class="reel-card-copy"><span>{service.index}</span><h3 data-scramble>{service.title}</h3><i>↗</i></div>
            </a>
          ))}
