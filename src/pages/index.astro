---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowCore from '../components/FlowCore.astro';
import EditorialJourney from '../components/EditorialJourney.astro';
import CitiesPhysicsBoard from '../components/CitiesPhysicsBoard.astro';
import VideoDivider from '../components/VideoDivider.astro';
import { services } from '../data/services.js';
import valueArchitectureImage from '../assets/generated/v4/service-value-diagnostic-atlas.png';
import chatbotKnowledgeImage from '../assets/generated/v4/service-chatbot-knowledge-dialogue.png';
import voicebotRobotImage from '../assets/generated/v4/service-voice-agent-resonance.png';
import careObservatoryImage from '../assets/generated/v4/service-care-command-observatory.png';
import seoAiCitationsImage from '../assets/generated/v4/service-geo-citation-ecosystem.png';
import aiAgentControlImage from '../assets/generated/v4/service-agent-human-control.png';
import processAutomationImage from '../assets/generated/v4/service-workflow-business-artifacts.png';
import humanAiTouchImage from '../assets/generated/v3/human-ai-touch.png';
import aiAgentControlV3Image from '../assets/generated/v3/ai-agent-control.png';
import aiCareObservatoryV3Image from '../assets/generated/v3/ai-care-observatory.png';
import chatbotKnowledgeV3Image from '../assets/generated/v3/chatbot-knowledge.png';
import processAutomationV3Image from '../assets/generated/v3/process-automation.png';
import seoAiCitationsV3Image from '../assets/generated/v3/seo-ai-citations.png';
import valueArchitectureV3Image from '../assets/generated/v3/value-architecture.png';
import voicebotRobotV3Image from '../assets/generated/v3/voicebot-robot.png';
import storyFirstSignalImage from '../assets/generated/v4/story-01-first-signal.png';
import storyValueDiagnosisImage from '../assets/generated/v4/story-02-value-diagnosis.png';
import storyContextMemoryImage from '../assets/generated/v4/story-03-context-memory.png';
import storySystemArchitectureImage from '../assets/generated/v4/story-04-system-architecture.png';
import storyLivePilotImage from '../assets/generated/v4/story-05-live-pilot.png';
import storyControlledActionImage from '../assets/generated/v4/story-06-controlled-action.png';
import storyObservableResultImage from '../assets/generated/v4/story-07-observable-result.png';
import storyScaleCareImage from '../assets/generated/v4/story-08-scale-and-care.png';

const marquee = ['Agenci AI', 'Voiceboty', 'Chatboty', 'Automatyzacje', 'SEO + GEO', 'Strony WWW', 'Opieka AI', 'Dane w UE'];
const serviceVisuals = {
  core: { src: valueArchitectureImage, alt: 'Warstwowa mapa strategii i priorytetów wdrożenia AI' },
  chat: { src: chatbotKnowledgeImage, alt: 'Modułowy chatbot łączący pytania klientów z wiedzą firmy' },
  search: { src: seoAiCitationsImage, alt: 'Treści strony prowadzące do odpowiedzi cytowanej przez system AI' },
  voice: { src: voicebotRobotImage, alt: 'Profesjonalny robot AI prowadzący naturalną rozmowę głosową' },
  agent: { src: aiAgentControlImage, alt: 'Agent AI prowadzący zadanie od sygnału do kontrolowanego działania' },
  automation: { src: processAutomationImage, alt: 'Silnik automatyzacji przesyłający dane przez kolejne etapy procesu' },
  care: { src: careObservatoryImage, alt: 'Centrum monitorowania agentów AI z wykrytym wyjątkiem systemowym' },
};
// Technika D (Azurio mxdHero3dImages): 22 zdjęcia rozlatujące się ze środka + okładka (story-06).
// Kształty p=portret, l=landscape, s=kwadrat; przypisywane cyklicznie dla wizualnej różnorodności.
const scatterShapes = ['p1', 'l1', 's1', 'p2', 'l2', 's2'];
const cinematicScatter = [
  storyFirstSignalImage,
  valueArchitectureV3Image,
  storyValueDiagnosisImage,
  chatbotKnowledgeImage,
  storyContextMemoryImage,
  voicebotRobotV3Image,
  storySystemArchitectureImage,
  careObservatoryImage,
  aiAgentControlV3Image,
  storyLivePilotImage,
  seoAiCitationsImage,
  humanAiTouchImage,
  storyObservableResultImage,
  processAutomationV3Image,
  valueArchitectureImage,
  storyScaleCareImage,
  chatbotKnowledgeV3Image,
  aiAgentControlImage,
  seoAiCitationsV3Image,
  voicebotRobotImage,
  aiCareObservatoryV3Image,
  processAutomationImage,
].map((src, index) => ({ src, shape: scatterShapes[index % scatterShapes.length] }));
const sequenceCards = [
  {
    variant: 'tall',
    title: 'Zasilane przez AI',
    tag: '01 / Sygnał · Kontekst · Architektura',
    aria: 'Zasilane przez AI: klatki pokazują sygnał wejściowy, kontekst wiedzy firmy i architekturę systemu',
    frames: [storyFirstSignalImage, storyContextMemoryImage, storySystemArchitectureImage],
  },
  {
    variant: 'wide',
    title: 'Kontrola człowieka',
    tag: '02 / Pilot · Decyzja',
    aria: 'Kontrola człowieka: klatki pokazują pilotaż na żywo i działanie przechodzące przez bramkę decyzji',
    frames: [storyLivePilotImage, storyControlledActionImage],
  },
  {
    variant: 'mid',
    title: 'Mierzalny wynik',
    tag: '03 / Wynik · Skala',
    aria: 'Mierzalny wynik: klatki pokazują zmierzony rezultat, skalowanie systemu i wartość dla biznesu',
    frames: [storyObservableResultImage, storyScaleCareImage, storyValueDiagnosisImage],
  },
];
const processSteps = [
  { index: '01', title: 'Diagnoza wartości', text: 'Wybieramy proces, w którym efekt będzie widoczny i mierzalny.', image: storyValueDiagnosisImage, alt: 'Diagnoza wartości: mapa procesu z zaznaczonym miejscem, w którym znika czas i sprzedaż' },
  { index: '02', title: 'Pierwszy system', text: 'Budujemy najmniejszą wersję, która naprawdę wykonuje pracę.', image: storySystemArchitectureImage, alt: 'Pierwszy system: architektura najmniejszej działającej wersji systemu AI' },
  { index: '03', title: 'Test na żywo', text: 'Sprawdzamy wyjątki, bezpieczeństwo i zachowanie w realnym procesie.', image: storyLivePilotImage, alt: 'Test na żywo: pilotaż systemu na realnych danych i realnym procesie' },
  { index: '04', title: 'Opieka i skala', text: 'Monitorujemy wynik, poprawiamy i dodajemy następne zadania.', image: storyScaleCareImage, alt: 'Opieka i skala: monitoring wyniku i rozwój systemu o kolejne zadania' },
];
const insightArticles = [
  { meta: 'Agenci AI / 08 min', title: 'Agent AI czy automatyzacja — od czego zacząć?', text: 'Prosty sposób na wybór pierwszego procesu bez przepalania budżetu.', image: aiAgentControlImage, alt: 'Modułowa architektura agenta AI z bramką kontroli' },
  { meta: 'SEO + GEO / 11 min', title: 'Jak być widocznym w odpowiedziach ChatGPT?', text: 'Co na stronie pomaga systemom AI właściwie zrozumieć markę.', image: seoAiCitationsImage, alt: 'Wizualizacja treści prowadzących do cytowanej odpowiedzi AI' },
  { meta: 'Operacje / 06 min', title: '7 zadań, które agent może przejąć w tym kwartale.', text: 'Praktyczna lista dla sprzedaży, obsługi i back office.', image: processAutomationImage, alt: 'Silnik automatyzacji z kontrolowanym przepływem danych' },
];
const serviceLoop = [...services, ...services];
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://www.simplefast.ai/#organization',
      name: 'SimpleFast.ai',
      url: 'https://www.simplefast.ai',
      email: 'kontakt@simplefast.ai',
      telephone: '+48696674874',
    },
    {
      '@type': 'ItemList',
      name: 'Usługi SimpleFast.ai',
      itemListElement: services.map((service, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        url: `https://www.simplefast.ai/uslugi/${service.slug}/`,
        name: service.title,
      })),
    },
  ],
};
---
<BaseLayout title="SimpleFast.ai — AI, które dowozi" schema={schema}>
  <main id="main">
    <section class="home-hero" data-hero>
      <div class="hero-sticky">
        <div class="hero-grid-lines"></div>
        <FlowCore />

        <div class="hero-copy">
          <div class="hero-kicker eyebrow"><i></i> Systemy AI dla firm / Polska + UE</div>
          <h1 class="hero-title">
            <span class="line"><span>AI, które</span></span>
            <span class="line"><span><em>dowozi.</em></span></span>
          </h1>
        </div>

        <ul class="hero-side-list" aria-label="Zakres usług">
          <li><span data-scramble>Architektura wartości</span></li>
          <li><span data-scramble>Agenci AI</span></li>
          <li><span data-scramble>Voice + chat</span></li>
          <li><span data-scramble>Automatyzacja</span></li>
          <li><span data-scramble>Web / SEO / GEO</span></li>
        </ul>

        <div class="hero-bottom">
          <p class="hero-intro">Projektujemy agentów, automatyzacje i cyfrowe doświadczenia, które zdejmują z zespołu realną pracę — nie tylko robią wrażenie na demo.</p>
          <div class="hero-actions">
            <a class="button button-primary magnetic" href="/kontakt/"><span>Umów diagnozę AI</span><span>↗</span></a>
            <a class="button magnetic" href="#uslugi"><span>Zobacz usługi</span><span>↓</span></a>
          </div>
          <a class="hero-scroll" href="#manifest">Przewiń</a>
        </div>
      </div>
    </section>

    <div class="marquee-band" aria-label="Zakres kompetencji">
      <div class="marquee-track">
        {[...marquee, ...marquee].map((item) => <span>{item}</span>)}
      </div>
    </div>

    <section class="manifesto" id="manifest" data-manifesto>
      <div class="manifesto-sticky">
      <div class="manifesto-pops" aria-hidden="true">
        <figure class="manifesto-pop manifesto-pop--1" data-manifesto-pop><Image src={storyFirstSignalImage} alt="" widths={[420, 640]} sizes="20vw" format="webp" quality={78} loading="lazy" /></figure>
        <figure class="manifesto-pop manifesto-pop--2" data-manifesto-pop><Image src={storyContextMemoryImage} alt="" widths={[420, 640]} sizes="20vw" format="webp" quality={78} loading="lazy" /></figure>
        <figure class="manifesto-pop manifesto-pop--3" data-manifesto-pop><Image src={storyLivePilotImage} alt="" widths={[420, 640]} sizes="20vw" format="webp" quality={78} loading="lazy" /></figure>
        <figure class="manifesto-pop manifesto-pop--4" data-manifesto-pop><Image src={storyControlledActionImage} alt="" widths={[420, 640]} sizes="20vw" format="webp" quality={78} loading="lazy" /></figure>
        <figure class="manifesto-pop manifesto-pop--5" data-manifesto-pop><Image src={storyObservableResultImage} alt="" widths={[420, 640]} sizes="20vw" format="webp" quality={78} loading="lazy" /></figure>
      </div>
      <div class="manifesto-grid section-shell">
        <p class="mono-label">/ <span data-scramble>Nasze podejście</span></p>
        <h2 aria-label="Nie wdrażamy AI dla efektu wow. Wdrażamy efekt, który widać w pracy.">
          <span class="manifesto-line"><span data-manifesto-line>Nie wdrażamy AI</span></span>
          <span class="manifesto-line"><span data-manifesto-line>dla efektu wow.</span></span>
          <span class="manifesto-line manifesto-line--muted"><span data-manifesto-line>Wdrażamy <em>efekt,</em></span></span>
          <span class="manifesto-line manifesto-line--muted"><span data-manifesto-line>który widać w pracy.</span></span>
        </h2>
        <ul class="manifesto-signals" data-manifesto-signals aria-label="Etapy podejścia SimpleFast.ai">
          <li><b data-scramble>01 / Znajdź stratę</b><i></i><span>Proces</span></li>
          <li><b data-scramble>02 / Zbuduj system</b><i></i><span>Próba</span></li>
          <li><b data-scramble>03 / Zmierz efekt</b><i></i><span>Dowód</span></li>
        </ul>
        <div class="manifesto-copy" data-manifesto-copy>
          <p>Najpierw znajdujemy proces, w którym znika czas lub sprzedaż. Dopiero potem dobieramy model, narzędzia i integracje.</p>
          <p>Budujemy mały, działający system, mierzymy efekt i rozwijamy go wtedy, kiedy biznes jest na to gotowy.</p>
        </div>
      </div>
      </div>
    </section>

    <section class="human-ai-bridge" data-human-bridge>
      <div class="human-ai-bridge__sticky">
        <div class="human-ai-bridge__media" data-human-bridge-media>
          <Image
            src={humanAiTouchImage}
            alt="Ludzka dłoń i precyzyjna dłoń robota spotykające się na granicy dwóch światów"
            widths={[960, 1440, 1920, 2400]}
            sizes="100vw"
            format="webp"
            quality={88}
            loading="lazy"
          />
        </div>
        <div class="human-ai-bridge__overlay" data-hb-overlay>
          <p class="mono-label" data-hb-kicker>/ Punkt styku</p>
          <h2 class="human-ai-bridge__title" aria-label="Zderzenie z technologią.">
            <span class="hb-line"><span data-hb-line>Zderzenie</span></span>
            <span class="hb-line"><span data-hb-line>z technologią.</span></span>
          </h2>
        </div>
      </div>
    </section>

    <section class="cinematic-system" data-cinematic aria-label="System AI w ruchu">
      <div class="cinematic-stage">
        <div class="cinematic-chapter"><span>[ System / w ruchu ]</span><span>Scroll to orchestrate</span></div>
        <h2 class="cinematic-title" aria-label="Od pierwszego sygnału do działania pod kontrolą.">
          <span aria-hidden="true" data-cinematic-intro-line>Od pierwszego</span>
          <span aria-hidden="true" data-cinematic-intro-line><em>sygnału</em></span>
        </h2>
        <div class="cinematic-scatter" aria-hidden="true">
          {cinematicScatter.map((shot) => (
            <figure class:list={['cinematic-shot', `cinematic-shot--${shot.shape}`]} data-cinematic-shot>
              <Image src={shot.src} alt="" widths={[480, 760, 1080]} sizes="30vw" format="webp" quality={78} loading="lazy" />
            </figure>
          ))}
        </div>
        <div class="cinematic-cover-layer">
          <figure class="cinematic-cover" data-cinematic-cover>
            <Image
              src={storyControlledActionImage}
              alt="Działanie agenta przechodzące przez bramkę kontroli człowieka"
              widths={[960, 1440, 1920]}
              sizes="100vw"
              format="webp"
              quality={85}
              loading="lazy"
            />
            <p class="cinematic-outro" aria-hidden="true">
              <span data-cinematic-outro-line>do działania</span>
              <span data-cinematic-outro-line><em>pod kontrolą.</em></span>
            </p>
          </figure>
        </div>
        <div class="cinematic-progress" aria-hidden="true"><i data-cinematic-progress></i></div>
      </div>
    </section>

    <EditorialJourney />

    <section class="sequence-lab" id="filary">
      <div class="sequence-grid section-shell">
        <div class="sequence-copy">
          <p class="mono-label">/ Jedno wdrożenie. Trzy filary.</p>
          <h2 data-reveal><span class="sq-hover-word">Najedź. </span>Zobacz, jak system dojrzewa.</h2>
          <p>Każda karta pokazuje inny filar tego samego wdrożenia: silnik AI, kontrolę człowieka i wynik, który da się zmierzyć.</p>
        </div>
        <div class="sequence-deck">
          {sequenceCards.map((card) => (
            <figure class:list={['sequence-card', `sequence-card--${card.variant}`]} data-sequence-card aria-label={card.aria}>
              <div class="sequence-card-frames" aria-hidden="true">
                {card.frames.map((frame, frameIndex) => (
                  <div class:list={['sequence-card-frame', frameIndex === 0 && 'is-active']} data-sequence-card-frame>
                    <Image src={frame} alt="" widths={[520, 780, 1080]} sizes="(max-width: 760px) 92vw, 32vw" format="webp" quality={82} loading="lazy" />
                  </div>
                ))}
              </div>
              <figcaption class="sequence-card-caption">
                <strong class="sequence-card-title">{card.title}</strong>
                <span class="sequence-card-tag"><span data-scramble>{card.tag}</span></span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="system-story" id="przeplyw">
      <div class="story-grid">
        <div class="story-media">
          <div class="story-media-frames">
            <Image class="is-active" data-story-visual="0" src={storyFirstSignalImage} alt="Agent AI odbiera pierwszy sygnał z rozmowy, wiadomości i systemów firmy" widths={[760, 1100, 1500]} sizes="(max-width: 760px) 100vw, 52vw" format="webp" quality={84} />
            <Image data-story-visual="1" src={storyContextMemoryImage} alt="" aria-hidden="true" widths={[760, 1100, 1500]} sizes="(max-width: 760px) 100vw, 52vw" format="webp" quality={84} />
            <Image data-story-visual="2" src={storyControlledActionImage} alt="" aria-hidden="true" widths={[760, 1100, 1500]} sizes="(max-width: 760px) 100vw, 52vw" format="webp" quality={84} />
          </div>
          <div class="story-media-copy"><span>Flow architecture</span><span>Scroll / 01—03</span></div>
        </div>
        <div class="story-steps">
          <div class="story-intro">
            <p class="mono-label">/ Od chaosu do wyniku</p>
            <h2>Jeden przepływ. Zero ręcznego pilnowania.</h2>
            <p>Agent łączy telefon, czat, e-mail, dokumenty i systemy firmy w proces, który ma początek, kontrolę i konkretny koniec.</p>
          </div>
          <article class="story-step" data-story-step>
            <span>01</span>
            <div>
              <h3>Słucha sygnału</h3>
              <p>Odbiera telefon, czyta wiadomość, dokument lub zmianę statusu w systemie.</p>
              <strong>Telefon · e-mail · formularz · CRM</strong>
            </div>
          </article>
          <article class="story-step" data-story-step>
            <span>02</span>
            <div>
              <h3>Rozumie kontekst</h3>
              <p>Korzysta z firmowej wiedzy i reguł, sprawdza dane oraz rozpoznaje, co wymaga decyzji człowieka.</p>
              <strong>Wiedza · zasady · bezpieczeństwo</strong>
            </div>
          </article>
          <article class="story-step" data-story-step>
            <span>03</span>
            <div>
              <h3>Wykonuje pracę</h3>
              <p>Umawia termin, aktualizuje CRM, tworzy dokument, przekazuje wyjątek i zapisuje każdą akcję.</p>
              <strong>Akcja · kontrola · wynik</strong>
            </div>
          </article>
        </div>
      </div>
    </section>

    <div class="video-triptych" aria-label="System w ruchu">
      <VideoDivider name="flow-tunnel" kicker="/ System w ruchu" height="xs" />
      <VideoDivider name="datacenter" kicker="/ Dane w UE · 24/7" height="xs" />
      <VideoDivider name="core-rings" kicker="/ Silnik, który pracuje" height="xs" />
    </div>

    <section class="services-section" id="uslugi">
      <div class="section-shell">
        <div class="section-heading">
          <p class="mono-label">/ 07 specjalizacji</p>
          <h2 data-reveal>Budujemy cały system AI.</h2>
          <p data-reveal>Od znalezienia wartości, przez wdrożenie, aż po codzienną opiekę i rozwój.</p>
        </div>

        <div class="services-stack">
          {services.map((service, index) => (
            <article class="service-card" data-accent={service.accent} style={`--index:${index}`}>
              <div class="service-card-copy">
                <div class="service-card-head"><span>{service.index}</span><span>{service.kicker}</span></div>
                <a class="service-card-link" href={`/uslugi/${service.slug}/`}><i>↗</i> <span data-scramble>Zobacz usługę</span></a>
                <h3>{service.title}</h3>
                <p class="service-card-desc">{service.short}</p>
                <div class="service-card-outcome"><span>Rezultat</span><p>{service.outcome}</p></div>
              </div>
              <div class="service-card-media">
                <Image src={serviceVisuals[service.visual].src} alt={serviceVisuals[service.visual].alt} widths={[640, 960, 1280]} sizes="(max-width: 760px) 100vw, 50vw" format="webp" quality={84} />
                <div class="service-media-ui" aria-hidden="true"><span>System / {service.index}</span><i></i><span>Live architecture</span></div>
                <span class="media-label">SimpleFast / {service.index}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="proof-explore" data-proof-explore aria-labelledby="proof-explore-title">
      <div class="proof-explore__sticky">
        <div class="proof-explore__media" aria-hidden="true">
          <figure class="proof-explore__img proof-explore__img--1" data-proof-img><Image src={valueArchitectureImage} alt="" widths={[640,960,1280]} sizes="42vw" format="webp" quality={82} loading="lazy" /></figure>
          <figure class="proof-explore__img proof-explore__img--2" data-proof-img><Image src={voicebotRobotImage} alt="" widths={[520,760,1080]} sizes="26vw" format="webp" quality={82} loading="lazy" /></figure>
          <figure class="proof-explore__img proof-explore__img--3" data-proof-img><Image src={seoAiCitationsImage} alt="" widths={[640,960,1280]} sizes="38vw" format="webp" quality={82} loading="lazy" /></figure>
          <figure class="proof-explore__img proof-explore__img--4" data-proof-img><Image src={processAutomationImage} alt="" widths={[640,960,1280]} sizes="38vw" format="webp" quality={82} loading="lazy" /></figure>
          <figure class="proof-explore__img proof-explore__img--5" data-proof-img><Image src={careObservatoryImage} alt="" widths={[520,760,1080]} sizes="26vw" format="webp" quality={82} loading="lazy" /></figure>
        </div>
        <p class="proof-explore__kicker mono-label" data-proof-kicker>[ Efekt w procesie ]</p>
        <h2 class="proof-explore__title" id="proof-explore-title" data-proof-title>
          <span data-proof-line>Technologia znika.</span>
          <span data-proof-line>Zostaje lepsza praca.</span>
        </h2>
      </div>
    </section>


    <section class="process-section" id="proces">
      <div class="section-shell">
        <div class="process-title">
          <p class="mono-label">/ Jak pracujemy</p>
          <h2 data-reveal>Mały krok. Szybki dowód. Stały rozwój.</h2>
        </div>
        <div class="process-list">
          {processSteps.map((step) => (
            <article class="process-item" data-process-row>
              <div class="process-item-inner" data-process-inner>
                <div class="process-item-head">
                  <span>{step.index}</span>
                  <h3><span class="process-title-sr">{step.title}</span><span aria-hidden="true" data-process-scramble>{step.title}</span></h3>
                </div>
                <div class="process-item-media">
                  <Image src={step.image} alt={step.alt} widths={[520, 780, 1080]} sizes="(max-width: 760px) 92vw, 34vw" format="webp" quality={82} loading="lazy" />
                </div>
                <p>{step.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="services-reel-section">
